<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="application.controllers.CourrierController">
   
   <!-- Barre d'outils supérieure -->
   <top>
      <VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: white;">
         
         <!-- En-tête -->
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;" text="📧 Gestion du Courrier">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleNouveauCourrier" styleClass="button-success" text="+ Nouveau courrier" />
            <Button onAction="#handleCourrierEntrant" styleClass="button-primary" text="📥 Courrier entrant" />
            <Button onAction="#handleCourrierSortant" styleClass="button-secondary" text="📤 Courrier sortant" />
            <Button onAction="#handleActualiser" styleClass="button-info" text="🔄 Actualiser" />
         </HBox>
         
         <!-- Filtres et recherche -->
         <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label text="Filtrer par:" />
            <ComboBox fx:id="filtreStatut" prefWidth="120.0" promptText="Statut">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Tous" />
                        <String fx:value="Nouveau" />
                        <String fx:value="En attente" />
                        <String fx:value="En cours" />
                        <String fx:value="Traité" />
                        <String fx:value="Archivé" />
                    </FXCollections>
                </items>
            </ComboBox>
            
            <ComboBox fx:id="filtrePriorite" prefWidth="120.0" promptText="Priorité">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Toutes" />
                        <String fx:value="Urgente" />
                        <String fx:value="Haute" />
                        <String fx:value="Normale" />
                        <String fx:value="Basse" />
                    </FXCollections>
                </items>
            </ComboBox>
            
            <DatePicker fx:id="dateDebut" promptText="Date début" />
            <DatePicker fx:id="dateFin" promptText="Date fin" />
            
            <Region HBox.hgrow="ALWAYS" />
            
            <TextField fx:id="champRecherche" prefWidth="250.0" promptText="🔍 Rechercher (objet, expéditeur...)" />
            <Button onAction="#handleRecherche" styleClass="button-primary" text="Rechercher" />
         </HBox>
         
      </VBox>
   </top>
   
   <!-- Zone principale avec tableau et détails -->
   <center>
      <SplitPane dividerPositions="0.6" orientation="HORIZONTAL">
         
         <!-- Liste des courriers -->
         <VBox spacing="10.0" style="-fx-padding: 20;">
            
            <!-- En-tête du tableau -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <Label style="-fx-font-weight: bold;" text="Liste des courriers" />
               <Label fx:id="nombreCourriers" style="-fx-text-fill: #7f8c8d;" text="(0 courriers)" />
               <Region HBox.hgrow="ALWAYS" />
            </HBox>
            
            <!-- Tableau des courriers -->
            <TableView fx:id="tableauCourriers" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colonneNumero" prefWidth="100.0" text="N° Courrier" />
                  <TableColumn fx:id="colonneType" prefWidth="80.0" text="Type" />
                  <TableColumn fx:id="colonneObjet" prefWidth="220.0" text="Objet" />
                  <TableColumn fx:id="colonneExpediteur" prefWidth="150.0" text="Expéditeur" />
                  <TableColumn fx:id="colonneDate" prefWidth="120.0" text="Date" />
                  <TableColumn fx:id="colonnePriorite" prefWidth="100.0" text="Priorité" />
                  <TableColumn fx:id="colonneStatut" prefWidth="100.0" text="Statut" />
               </columns>
               
               <!-- Placeholder quand vide -->
               <placeholder>
                  <VBox alignment="CENTER" spacing="10.0">
                     <Label style="-fx-font-size: 48px; -fx-text-fill: #bdc3c7;" text="📧" />
                     <Label style="-fx-text-fill: #7f8c8d;" text="Aucun courrier trouvé" />
                     <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 12px;" 
                            text="Modifiez vos critères de recherche ou ajoutez un nouveau courrier" />
                  </VBox>
               </placeholder>
            </TableView>
            
         </VBox>
         
         <!-- Panneau de détails -->
         <VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #f8f9fa;">
            
            <!-- En-tête des détails -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Détails du courrier" />
               <Region HBox.hgrow="ALWAYS" />
               <Button fx:id="btnModifier" styleClass="button-primary" text="✏️" />
               <Button fx:id="btnSupprimer" styleClass="button-danger" text="🗑️" />
            </HBox>
            
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
               <VBox fx:id="panneauDetails" spacing="15.0">
                  
                  <!-- Informations générales -->
                  <VBox spacing="10.0" styleClass="card">
                     <Label style="-fx-font-weight: bold;" text="Informations générales" />
                     
                     <GridPane hgap="10.0" vgap="8.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="NEVER" minWidth="100.0" />
                           <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        
                        <Label text="Numéro:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="labelNumero" style="-fx-font-weight: bold;" text="--" 
                               GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label fx:id="labelType" text="--" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label text="Objet:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label fx:id="labelObjet" text="--" wrapText="true" 
                               GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        
                        <Label text="Expéditeur:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <Label fx:id="labelExpediteur" text="--" 
                               GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        
                        <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <Label fx:id="labelDate" text="--" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        
                        <Label text="Priorité:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <Label fx:id="labelPriorite" style="-fx-font-weight: bold;" text="--" 
                               GridPane.columnIndex="1" GridPane.rowIndex="5" />
                        
                        <Label text="Statut:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                        <Label fx:id="labelStatut" style="-fx-font-weight: bold;" text="--" 
                               GridPane.columnIndex="1" GridPane.rowIndex="6" />
                     </GridPane>
                  </VBox>
                  
                  <!-- Notes et commentaires -->
                  <VBox spacing="10.0" styleClass="card">
                     <Label style="-fx-font-weight: bold;" text="Notes et commentaires" />
                     <TextArea fx:id="textAreaNotes" prefRowCount="4" editable="false"
                              promptText="Aucune note" wrapText="true" />
                  </VBox>
                  
               </VBox>
            </ScrollPane>
            
            <!-- Actions rapides -->
            <VBox spacing="8.0">
               <Label style="-fx-font-weight: bold;" text="Actions rapides" />
               <HBox spacing="8.0">
                  <Button fx:id="btnMarquerTraite" styleClass="button-success" text="✅ Traiter" />
                  <Button fx:id="btnCoter" styleClass="button-warning" text="📌 Coter" />
               </HBox>
               <HBox spacing="8.0">
                  <Button fx:id="btnTransferer" styleClass="button-info" text="➡️ Transférer" />
                  <Button fx:id="btnArchiver" styleClass="button-secondary" text="📁 Archiver" />
               </HBox>
               <HBox spacing="8.0">
                  <Button fx:id="btnImprimer" styleClass="button-secondary" text="🖨️ Imprimer" />
               </HBox>
            </VBox>
            
         </VBox>
         
      </SplitPane>
   </center>
   
</BorderPane>
