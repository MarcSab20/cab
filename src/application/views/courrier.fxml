<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>


<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controllers.CourrierController">
   
   <!-- Barre d'outils supérieure -->
   <top>
      <VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: white;">
         
         <!-- En-tête -->
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;" text="Gestion du Courrier">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button styleClass="button-success" text="+ Nouveau courrier" />
            <Button styleClass="button-primary" text="📧 Courrier entrant" />
            <Button styleClass="button-secondary" text="📤 Courrier sortant" />
         </HBox>
         
         <!-- Filtres et recherche -->
         <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label text="Filtrer par:" />
            <ComboBox fx:id="filtreStatut" prefWidth="120.0" promptText="Statut">
			    <items>
			        <FXCollections fx:factory="observableArrayList">
			            <String fx:value="Tous" />
			            <String fx:value="En attente" />
			            <String fx:value="En cours" />
			            <String fx:value="Traité" />
			            <String fx:value="Archivé" />
			        </FXCollections>
			    </items>
			</ComboBox>
            
            <ComboBox fx:id="filtrePriorite" prefWidth="120.0" promptText="Priorité">
			    <items>
			        <FXCollections fx:factory="observableArrayList">
			            <String fx:value="Toutes" />
			            <String fx:value="Urgente" />
			            <String fx:value="Haute" />
			            <String fx:value="Normale" />
			            <String fx:value="Basse" />
			        </FXCollections>
			    </items>
			</ComboBox>
            
            <DatePicker fx:id="dateDebut" promptText="Date début" />
            <DatePicker fx:id="dateFin" promptText="Date fin" />
            
            <Region HBox.hgrow="ALWAYS" />
            
            <TextField fx:id="champRecherche" prefWidth="250.0" promptText="🔍 Rechercher (objet, expéditeur...)" />
            <Button styleClass="button-primary" text="Rechercher" />
            <Button styleClass="button-secondary" text="Réinitialiser" />
         </HBox>
         
      </VBox>
   </top>
   
   <!-- Zone principale avec tableau et détails -->
   <center>
      <SplitPane dividerPositions="0.6" orientation="HORIZONTAL">
         
         <!-- Liste des courriers -->
         <VBox spacing="10.0" style="-fx-padding: 20;">
            
            <!-- En-tête du tableau -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <Label style="-fx-font-weight: bold;" text="Liste des courriers" />
               <Label fx:id="nombreCourriers" style="-fx-text-fill: #7f8c8d;" text="(125 courriers)" />
               <Region HBox.hgrow="ALWAYS" />
               <Button text="📊 Exporter" />
               <Button text="🔄 Actualiser" />
            </HBox>
            
            <!-- Tableau des courriers -->
            <TableView fx:id="tableauCourriers" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colonneNumero" prefWidth="80.0" text="N°" />
                  <TableColumn fx:id="colonneType" prefWidth="60.0" text="Type" />
                  <TableColumn fx:id="colonneObjet" prefWidth="200.0" text="Objet" />
                  <TableColumn fx:id="colonneExpediteur" prefWidth="150.0" text="Expéditeur" />
                  <TableColumn fx:id="colonneDate" prefWidth="100.0" text="Date" />
                  <TableColumn fx:id="colonnePriorite" prefWidth="80.0" text="Priorité" />
                  <TableColumn fx:id="colonneStatut" prefWidth="80.0" text="Statut" />
                  <TableColumn fx:id="colonneActions" prefWidth="100.0" text="Actions" />
               </columns>
               
               <!-- Placeholder quand vide -->
               <placeholder>
                  <VBox alignment="CENTER" spacing="10.0">
                     <Label style="-fx-font-size: 48px; -fx-text-fill: #bdc3c7;" text="📧" />
                     <Label style="-fx-text-fill: #7f8c8d;" text="Aucun courrier trouvé" />
                     <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 12px;" text="Modifiez vos critères de recherche ou ajoutez un nouveau courrier" />
                  </VBox>
               </placeholder>
            </TableView>
            
            <!-- Pagination -->
            <HBox alignment="CENTER" spacing="10.0">
               <Button text="« Précédent" />
               <Label text="Page 1 sur 5" />
               <Button text="Suivant »" />
               <Region HBox.hgrow="ALWAYS" />
               <Label text="Éléments par page:" />
               <ComboBox fx:id="limitComboBox" prefWidth="60.0">
				    <items>
				        <FXCollections fx:factory="observableArrayList">
				            <String fx:value="10" />
				            <String fx:value="25" />
				            <String fx:value="50" />
				            <String fx:value="100" />
				        </FXCollections>
				    </items>
				</ComboBox>
            </HBox>
            
         </VBox>
         
         <!-- Panneau de détails -->
         <VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #f8f9fa;">
            
            <!-- En-tête des détails -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Détails du courrier" />
               <Region HBox.hgrow="ALWAYS" />
               <Button fx:id="btnModifier" styleClass="button-primary" text="✏️ Modifier" />
               <Button fx:id="btnSupprimer" styleClass="button-danger" text="🗑️ Supprimer" />
            </HBox>
            
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
               <VBox fx:id="panneauDetails" spacing="15.0">
                  
                  <!-- Informations générales -->
                  <VBox spacing="10.0" styleClass="card">
                     <Label style="-fx-font-weight: bold;" text="Informations générales" />
                     
                     <GridPane hgap="10.0" vgap="8.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="NEVER" minWidth="100.0" />
                           <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        
                        <Label text="Numéro:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="labelNumero" style="-fx-font-weight: bold;" text="CRR-2025-001" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label fx:id="labelType" text="Entrant" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label text="Objet:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label fx:id="labelObjet" text="Demande de devis" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        
                        <Label text="Expéditeur:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <Label fx:id="labelExpediteur" text="Société ABC" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        
                        <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <Label fx:id="labelDate" text="04/11/2025 14:30" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        
                        <Label text="Priorité:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <Label fx:id="labelPriorite" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;" text="🔴 Haute" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                        
                        <Label text="Statut:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                        <Label fx:id="labelStatut" style="-fx-text-fill: #f39c12; -fx-font-weight: bold;" text="🟡 En cours" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                     </GridPane>
                  </VBox>
                  
                  <!-- Traitement -->
                  <VBox spacing="10.0" styleClass="card">
                     <Label style="-fx-font-weight: bold;" text="Traitement" />
                     
                     <GridPane hgap="10.0" vgap="8.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="NEVER" minWidth="100.0" />
                           <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        
                        <Label text="Traité par:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="labelTraitePar" text="Jean Dupont" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Date début:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label fx:id="labelDateDebut" text="04/11/2025 15:00" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label text="Échéance:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label fx:id="labelEcheance" style="-fx-text-fill: #e74c3c;" text="06/11/2025" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                     </GridPane>
                  </VBox>
                  
                  <!-- Notes et commentaires -->
                  <VBox spacing="10.0" styleClass="card">
                     <Label style="-fx-font-weight: bold;" text="Notes et commentaires" />
                     <TextArea fx:id="textAreaNotes" prefRowCount="4" promptText="Ajouter des notes..." wrapText="true" />
                     <HBox alignment="CENTER_RIGHT" spacing="10.0">
                        <Button styleClass="button-secondary" text="Annuler" />
                        <Button styleClass="button-primary" text="Sauvegarder" />
                     </HBox>
                  </VBox>
                  
                  <!-- Pièces jointes -->
                  <VBox spacing="10.0" styleClass="card">
                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label style="-fx-font-weight: bold;" text="Pièces jointes" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button styleClass="button-info" text="+ Ajouter" />
                     </HBox>
                     
                     <VBox fx:id="listePiecesJointes" spacing="5.0">
                        <!-- Exemple de pièce jointe -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 8; -fx-background-color: white; -fx-background-radius: 4;">
                           <Label style="-fx-font-size: 16px;" text="📄" />
                           <VBox HBox.hgrow="ALWAYS">
                              <Label style="-fx-font-weight: bold;" text="demande_devis.pdf" />
                              <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="245 KB - PDF" />
                           </VBox>
                           <Button text="👁️" />
                           <Button text="💾" />
                           <Button styleClass="button-danger" text="🗑️" />
                        </HBox>
                     </VBox>
                  </VBox>
                  
                  <!-- Historique -->
                  <VBox spacing="10.0" styleClass="card">
                     <Label style="-fx-font-weight: bold;" text="Historique" />
                     
                     <VBox spacing="8.0">
                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 8; -fx-background-color: white; -fx-background-radius: 4;">
                           <VBox alignment="CENTER">
                              <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="15:00" />
                              <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="04/11" />
                           </VBox>
                           <VBox HBox.hgrow="ALWAYS">
                              <Label style="-fx-font-weight: bold;" text="Courrier assigné" />
                              <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Assigné à Jean Dupont" />
                           </VBox>
                        </HBox>
                        
                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 8; -fx-background-color: white; -fx-background-radius: 4;">
                           <VBox alignment="CENTER">
                              <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="14:30" />
                              <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="04/11" />
                           </VBox>
                           <VBox HBox.hgrow="ALWAYS">
                              <Label style="-fx-font-weight: bold;" text="Courrier reçu" />
                              <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Enregistré dans le système" />
                           </VBox>
                        </HBox>
                     </VBox>
                  </VBox>
                  
               </VBox>
            </ScrollPane>
            
            <!-- Actions rapides -->
            <VBox spacing="8.0">
               <Label style="-fx-font-weight: bold;" text="Actions rapides" />
               <HBox spacing="8.0">
                  <Button fx:id="btnMarquerTraite" styleClass="button-success" text="✅ Marquer traité" />
                  <Button fx:id="btnArchiver" styleClass="button-secondary" text="📁 Archiver" />
               </HBox>
               <HBox spacing="8.0">
                  <Button fx:id="btnTransferer" styleClass="button-info" text="↗️ Transférer" />
                  <Button fx:id="btnImprimer" styleClass="button-secondary" text="🖨️ Imprimer" />
               </HBox>
            </VBox>
            
         </VBox>
         
      </SplitPane>
   </center>
   
</BorderPane>