<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainContainer" xmlns="http://javafx.com/javafx/11.0.1" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="application.controllers.VisioconferenceController"
            prefWidth="1200.0" prefHeight="800.0">
   
   <!-- Barre d'outils supérieure -->
   <top>
      <VBox spacing="0">
         
         <!-- En-tête -->
         <HBox alignment="CENTER_LEFT" spacing="15.0" 
               style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="📹 Visioconférence" style="-fx-text-fill: white; -fx-font-weight: bold;">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            
            <Separator orientation="VERTICAL" style="-fx-background-color: white;" />
            
            <VBox spacing="2.0">
               <Label fx:id="labelTitreReunion" text="Réunion d'équipe" 
                     style="-fx-text-fill: white; -fx-font-weight: bold;" />
               <Label fx:id="labelParticipants" text="5 participants" 
                     style="-fx-text-fill: #bdc3c7; -fx-font-size: 11px;" />
            </VBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <!-- Statut de connexion -->
            <HBox spacing="10.0" alignment="CENTER">
               <Label fx:id="labelStatut" text="Connecté" 
                     style="-fx-text-fill: #2ecc71; -fx-font-size: 12px;" />
               <ProgressBar fx:id="progressBar" prefWidth="150.0" visible="false" />
            </HBox>
         </HBox>
         
         <!-- Barre de contrôles -->
         <HBox alignment="CENTER" spacing="10.0" 
               style="-fx-background-color: #34495e; -fx-padding: 10;">
            
            <!-- Contrôles média -->
            <Button fx:id="btnMicrophone" text="🎤 Micro" styleClass="button-control">
			    <tooltip>
			        <Tooltip text="Activer/Désactiver le microphone" />
			    </tooltip>
			</Button>
			
			<Button fx:id="btnCamera" text="📹 Caméra" styleClass="button-control">
			    <tooltip>
			        <Tooltip text="Activer/Désactiver la caméra" />
			    </tooltip>
			</Button>
			
			<Button fx:id="btnPartagerEcran" text="🖥️ Partage" styleClass="button-control">
			    <tooltip>
			        <Tooltip text="Partager l'écran" />
			    </tooltip>
			</Button>
			
			<Separator orientation="VERTICAL" />
            
            <!-- Contrôles de la fenêtre -->
            <Button fx:id="btnRecharger" onAction="#handleRecharger" text="🔄 Recharger" 
			       styleClass="button-info">
			    <tooltip>
			        <Tooltip text="Recharger la visioconférence" />
			    </tooltip>
			</Button>
			
			<Region HBox.hgrow="ALWAYS" />
			
			<Button fx:id="btnQuitter" onAction="#handleQuitter" text="❌ Quitter" 
			       styleClass="button-danger">
			    <tooltip>
			        <Tooltip text="Quitter la visioconférence" />
			    </tooltip>
			</Button>
         </HBox>
         
      </VBox>
   </top>
   
   <!-- Zone WebView -->
   <center>
      <StackPane style="-fx-background-color: #2c3e50;">
         <WebView fx:id="webView" />
         
         <!-- Placeholder si pas de connexion -->
         <VBox alignment="CENTER" spacing="20.0" visible="false" managed="false">
            <Label text="📡" style="-fx-font-size: 72px;" />
            <Label text="Connexion à la visioconférence..." 
                  style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
            <ProgressIndicator />
         </VBox>
      </StackPane>
   </center>
   
   <!-- Pied de page avec informations -->
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="15.0" 
            style="-fx-background-color: #ecf0f1; -fx-padding: 10;">
         <Label text="💡 Astuce:" style="-fx-font-weight: bold;" />
         <Label text="Utilisez les contrôles dans Jitsi Meet pour gérer votre audio/vidéo" 
               style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
         <Region HBox.hgrow="ALWAYS" />
         <Label text="Powered by Jitsi Meet" style="-fx-text-fill: #95a5a6; -fx-font-size: 10px;" />
      </HBox>
   </bottom>
   
</BorderPane>
