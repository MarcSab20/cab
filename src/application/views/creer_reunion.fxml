<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="application.controllers.CreerReunionController"
            prefWidth="900.0" prefHeight="700.0">
   
   <!-- En-tête -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #3498db; -fx-padding: 20;">
         <Label text="📅 Programmer une réunion" style="-fx-text-fill: white; -fx-font-weight: bold;">
            <font>
               <Font size="20.0" />
            </font>
         </Label>
      </HBox>
   </top>
   
   <!-- Contenu principal -->
   <center>
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
         <VBox spacing="20.0" style="-fx-padding: 20;">
            
            <!-- Section : Informations générales -->
            <VBox spacing="15.0" styleClass="card">
               <Label text="ℹ️ Informations générales" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
               
               <GridPane hgap="15.0" vgap="12.0">
                  <columnConstraints>
                     <ColumnConstraints hgrow="NEVER" minWidth="120.0" />
                     <ColumnConstraints hgrow="ALWAYS" />
                  </columnConstraints>
                  
                  <!-- Titre -->
                  <Label text="Titre *" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <TextField fx:id="champTitre" promptText="Ex: Réunion d'équipe hebdomadaire" 
                            GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  
                  <!-- Description -->
                  <Label text="Description" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <TextArea fx:id="champDescription" promptText="Description de la réunion..." 
                           prefRowCount="3" wrapText="true"
                           GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  
                  <!-- Date et heure -->
                  <Label text="Date *" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                  <HBox spacing="10.0" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="2">
                     <DatePicker fx:id="datePicker" prefWidth="180.0" />
                     <Label text="à" />
                     <Spinner fx:id="spinnerHeure" prefWidth="70.0" />
                     <Label text=":" />
                     <Spinner fx:id="spinnerMinute" prefWidth="70.0" />
                  </HBox>
                  
                  <!-- Durée -->
                  <Label text="Durée" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                  <HBox spacing="10.0" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="3">
                     <Spinner fx:id="spinnerDuree" prefWidth="100.0" />
                     <Label text="minutes" />
                  </HBox>
                  
                  <!-- Lieu -->
                  <Label text="Lieu" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                  <TextField fx:id="champLieu" promptText="Salle de conférence, Bureau, etc." 
                            GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  
                  <!-- Visioconférence -->
                  <Label text="Visioconférence" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                  <HBox spacing="10.0" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="5">
                     <CheckBox fx:id="checkVisio" text="Activer la visioconférence (Jitsi Meet)" />
                     <Label text="ℹ️ Un lien sera généré automatiquement" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                  </HBox>
               </GridPane>
            </VBox>
            
            <!-- Section : Ordre du jour -->
            <VBox spacing="15.0" styleClass="card">
               <Label text="📝 Ordre du jour" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
               <TextArea fx:id="champOrdreDuJour" promptText="Points à aborder lors de la réunion..." 
                        prefRowCount="4" wrapText="true" />
            </VBox>
            
            <!-- Section : Participants -->
            <VBox spacing="15.0" styleClass="card">
               <Label text="👥 Participants *" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
               
               <!-- Filtres et recherche -->
               <HBox spacing="10.0" alignment="CENTER_LEFT">
                  <TextField fx:id="champRechercheUtilisateurs" promptText="🔍 Rechercher..." prefWidth="250.0" />
                  <CheckBox fx:id="checkUtilisateursActifs" text="Afficher uniquement les utilisateurs en ligne" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#ajouterTousUtilisateurs" text="Ajouter tous" styleClass="button-info" />
               </HBox>
               
               <!-- Listes de sélection -->
               <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                  
                  <!-- Utilisateurs disponibles -->
                  <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                     <Label text="Utilisateurs disponibles" style="-fx-font-weight: bold;" />
                     <ListView fx:id="listeUtilisateursDisponibles" prefHeight="200.0" VBox.vgrow="ALWAYS">
                        <placeholder>
                           <Label text="Aucun utilisateur disponible" style="-fx-text-fill: #95a5a6;" />
                        </placeholder>
                     </ListView>
                  </VBox>
                  
                  <!-- Boutons de transfert -->
                  <VBox spacing="10.0" alignment="CENTER">
                     <Button fx:id="btnAjouterParticipant" onAction="#ajouterParticipant" 
                            text="➡️" prefWidth="60.0" styleClass="button-primary" />
                     <Button fx:id="btnRetirerParticipant" onAction="#retirerParticipant" 
                            text="⬅️" prefWidth="60.0" styleClass="button-secondary" />
                  </VBox>
                  
                  <!-- Participants sélectionnés -->
                  <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                     <Label text="Participants sélectionnés" style="-fx-font-weight: bold;" />
                     <ListView fx:id="listeParticipantsSelectionnes" prefHeight="200.0" VBox.vgrow="ALWAYS">
                        <placeholder>
                           <Label text="Aucun participant sélectionné" style="-fx-text-fill: #95a5a6;" />
                        </placeholder>
                     </ListView>
                  </VBox>
                  
               </HBox>
               
               <Label text="💡 Astuce: Double-cliquez sur un utilisateur pour l'ajouter/retirer" 
                     style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px; -fx-font-style: italic;" />
               
            </VBox>
            
         </VBox>
      </ScrollPane>
   </center>
   
   <!-- Boutons d'action -->
   <bottom>
      <HBox spacing="15.0" alignment="CENTER_RIGHT" style="-fx-padding: 20; -fx-background-color: #ecf0f1;">
         <Button fx:id="btnAnnuler" onAction="#handleAnnuler" text="❌ Annuler" 
                styleClass="button-secondary" prefWidth="120.0" />
         <Button fx:id="btnCreer" onAction="#handleCreer" text="✅ Créer la réunion" 
                styleClass="button-success" prefWidth="150.0" />
      </HBox>
   </bottom>
   
</BorderPane>
