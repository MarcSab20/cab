<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controllers.WorkflowDashboardController">
   
   <!-- Barre supérieure -->
   <top>
      <VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: white;">
         
         <!-- En-tête -->
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;" text="📊 Dashboard Workflow - Suivi des Courriers">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleActualiser" styleClass="button-primary" text="🔄 Actualiser" />
         </HBox>
         
         <!-- Statistiques -->
         <GridPane hgap="15.0" vgap="10.0">
            <columnConstraints>
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
            </columnConstraints>
            
            <!-- Total courriers -->
            <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" GridPane.columnIndex="0">
               <Label style="-fx-font-size: 32px;" text="📧" />
               <Label fx:id="statTotal" styleClass="stat-number" style="-fx-text-fill: #3498db;" text="0" />
               <Label styleClass="stat-label" text="Total courriers" />
            </VBox>
            
            <!-- En cours -->
            <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" GridPane.columnIndex="1">
               <Label style="-fx-font-size: 32px;" text="⏳" />
               <Label fx:id="statEnCours" styleClass="stat-number" style="-fx-text-fill: #f39c12;" text="0" />
               <Label styleClass="stat-label" text="En cours" />
            </VBox>
            
            <!-- Terminés -->
            <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" GridPane.columnIndex="2">
               <Label style="-fx-font-size: 32px;" text="✅" />
               <Label fx:id="statTermines" styleClass="stat-number" style="-fx-text-fill: #27ae60;" text="0" />
               <Label styleClass="stat-label" text="Terminés" />
            </VBox>
            
            <!-- En retard -->
            <VBox alignment="CENTER" spacing="8.0" styleClass="stat-card" GridPane.columnIndex="3">
               <Label style="-fx-font-size: 32px;" text="⚠️" />
               <Label fx:id="statRetard" styleClass="stat-number" style="-fx-text-fill: #e74c3c;" text="0" />
               <Label styleClass="stat-label" text="En retard" />
            </VBox>
         </GridPane>
         
         <!-- Filtres -->
         <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label text="Filtrer par:" />
            <ComboBox fx:id="filtreService" prefWidth="150.0" promptText="Service" />
            <ComboBox fx:id="filtreStatut" prefWidth="120.0" promptText="Statut">
               <items>
                  <FXCollections fx:factory="observableArrayList">
                     <String fx:value="Tous" />
                     <String fx:value="En cours" />
                     <String fx:value="Traité" />
                     <String fx:value="En retard" />
                  </FXCollections>
               </items>
            </ComboBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <TextField fx:id="champRecherche" prefWidth="250.0" promptText="🔍 Rechercher..." />
         </HBox>
         
      </VBox>
   </top>
   
   <!-- Zone principale -->
   <center>
      <SplitPane dividerPositions="0.5" orientation="HORIZONTAL">
         
         <!-- Liste des courriers -->
         <VBox spacing="10.0" style="-fx-padding: 20;">
            
            <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Liste des courriers en workflow" />
            
            <TableView fx:id="tableauCourriers" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colonneNumero" prefWidth="100.0" text="N° Courrier" />
                  <TableColumn fx:id="colonneObjet" prefWidth="200.0" text="Objet" />
                  <TableColumn fx:id="colonneServiceActuel" prefWidth="120.0" text="Service actuel" />
                  <TableColumn fx:id="colonneEtape" prefWidth="80.0" text="Étape" />
                  <TableColumn fx:id="colonneStatut" prefWidth="100.0" text="Statut" />
                  <TableColumn fx:id="colonnePriorite" prefWidth="100.0" text="Priorité" />
                  <TableColumn fx:id="colonneActions" prefWidth="100.0" text="Actions" />
               </columns>
               
               <placeholder>
                  <VBox alignment="CENTER" spacing="10.0">
                     <Label style="-fx-font-size: 48px; -fx-text-fill: #bdc3c7;" text="📭" />
                     <Label style="-fx-text-fill: #7f8c8d;" text="Aucun courrier en workflow" />
                  </VBox>
               </placeholder>
            </TableView>
            
         </VBox>
         
         <!-- Visualisation du workflow -->
         <VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #f8f9fa;">
            
            <VBox spacing="10.0">
               <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Chaîne de suivi" />
               <Label fx:id="labelCourrierSelectionne" style="-fx-text-fill: #666; -fx-font-size: 12px;" 
                      text="Sélectionnez un courrier pour voir son workflow" wrapText="true" />
            </VBox>
            
            <Separator />
            
            <ScrollPane fx:id="workflowPane" fitToWidth="true" VBox.vgrow="ALWAYS" 
                       style="-fx-background-color: transparent; -fx-border-width: 0;">
               <VBox fx:id="workflowContainer" spacing="10.0">
                  
                  <!-- Le workflow sera construit dynamiquement -->
                  <VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 50;">
                     <Label style="-fx-font-size: 48px; -fx-text-fill: #bdc3c7;" text="🔄" />
                     <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" 
                            text="Sélectionnez un courrier dans la liste" />
                     <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 12px;" 
                            text="pour visualiser sa chaîne de workflow" />
                  </VBox>
                  
               </VBox>
            </ScrollPane>
            
            <!-- Légende -->
            <VBox spacing="8.0" style="-fx-padding: 15; -fx-background-color: white; -fx-background-radius: 6;">
               <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Légende" />
               
               <HBox spacing="20.0">
                  <HBox alignment="CENTER_LEFT" spacing="5.0">
                     <Label style="-fx-font-size: 12px;" text="🔵" />
                     <Label style="-fx-font-size: 11px; -fx-text-fill: #666;" text="Étape en cours" />
                  </HBox>
                  
                  <HBox alignment="CENTER_LEFT" spacing="5.0">
                     <Label style="-fx-font-size: 12px;" text="🟢" />
                     <Label style="-fx-font-size: 11px; -fx-text-fill: #666;" text="Étape terminée" />
                  </HBox>
                  
                  <HBox alignment="CENTER_LEFT" spacing="5.0">
                     <Label style="-fx-font-size: 12px;" text="⚪" />
                     <Label style="-fx-font-size: 11px; -fx-text-fill: #666;" text="Étape en attente" />
                  </HBox>
               </HBox>
            </VBox>
            
         </VBox>
         
      </SplitPane>
   </center>
   
</BorderPane>
