<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="application.controllers.WorkflowSuiviController"
            style="-fx-background-color: #ecf0f1;"
            minWidth="1200" minHeight="800" prefWidth="1400" prefHeight="900">
   
   <!-- EN-TÊTE -->
   <top>
      <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 2 0;">
         
         <!-- Titre principal -->
         <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: linear-gradient(to right, #2c3e50, #34495e); -fx-padding: 20; -fx-background-radius: 10;">
            <Label text="📊 Visualisation Dynamique des Flux de Courriers" 
                   style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
         </HBox>
         
         <!-- Choix du mode de visualisation -->
         <VBox spacing="10" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #3498db; -fx-border-width: 2; -fx-border-radius: 8;">
            <Label text="🎯 MODE DE VISUALISATION" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
            
            <HBox spacing="30" alignment="CENTER_LEFT">
               <!-- Radio buttons pour le mode -->
               <HBox spacing="15">
                  <RadioButton fx:id="rbModeCollectif" text="📊 Vue Collective (Tous les courriers)" 
                              selected="true"
                              style="-fx-font-size: 13px; -fx-font-weight: bold;">
                     <toggleGroup>
                        <ToggleGroup fx:id="modeToggleGroup"/>
                     </toggleGroup>
                  </RadioButton>
                  
                  <RadioButton fx:id="rbModeIndividuel" text="🔍 Vue Individuelle (Un courrier)" 
                              toggleGroup="$modeToggleGroup"
                              style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
               </HBox>
               
               <Separator orientation="VERTICAL" prefHeight="30"/>
               
               <!-- Sélection du courrier (pour mode individuel) -->
               <VBox spacing="5" fx:id="courrierSelectionBox" disable="true">
                  <Label text="📧 Sélectionner un courrier" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 12px;"/>
                  <HBox spacing="10" alignment="CENTER_LEFT">
                     <ComboBox fx:id="cbCourrierSelection" prefWidth="300" promptText="Choisissez un courrier..."/>
                     <Button fx:id="btnRechercherCourrier" text="🔍" 
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 12; -fx-background-radius: 6;"/>
                  </HBox>
               </VBox>
            </HBox>
         </VBox>
         
         <!-- Contrôles (pour mode collectif) -->
         <VBox fx:id="controlesModeCollectif" spacing="10">
            <HBox spacing="20" alignment="CENTER_LEFT">
               <VBox spacing="5">
                  <Label text="🎯 Type de Flux" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                  <ComboBox fx:id="cbTypeFlux" prefWidth="220"/>
               </VBox>
               
               <VBox spacing="5">
                  <Label text="📅 Du" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                  <DatePicker fx:id="dpDebut" prefWidth="160"/>
               </VBox>
               
               <VBox spacing="5">
                  <Label text="📅 Au" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                  <DatePicker fx:id="dpFin" prefWidth="160"/>
               </VBox>
               
               <Region HBox.hgrow="ALWAYS"/>
               
               <VBox spacing="5" alignment="BOTTOM_CENTER">
                  <Label text=" "/>
                  <HBox spacing="10">
                     <CheckBox fx:id="chkAfficherStatistiques" text="📊 Statistiques" selected="true"/>
                     <CheckBox fx:id="chkAfficherGoulots" text="⚠️ Goulots" selected="true"/>
                  </HBox>
               </VBox>
            </HBox>
         </VBox>
         
         <!-- Informations du courrier sélectionné (pour mode individuel) -->
         <VBox fx:id="infoCourrierIndividuel" spacing="8" visible="false" managed="false"
               style="-fx-background-color: #e8f4f8; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #3498db; -fx-border-width: 2; -fx-border-radius: 8;">
            <Label fx:id="lblCourrierNumero" text="📧 Courrier: -" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
            <HBox spacing="20">
               <Label fx:id="lblCourrierObjet" text="Objet: -" style="-fx-font-size: 12px; -fx-text-fill: #34495e;"/>
               <Label fx:id="lblCourrierType" text="Type: -" style="-fx-font-size: 12px; -fx-text-fill: #34495e;"/>
               <Label fx:id="lblCourrierDate" text="Date: -" style="-fx-font-size: 12px; -fx-text-fill: #34495e;"/>
               <Label fx:id="lblCourrierStatut" text="Statut: -" style="-fx-font-size: 12px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
            </HBox>
         </VBox>
         
         <!-- Zoom -->
         <HBox spacing="15" alignment="CENTER">
            <Label text="🔍 Zoom:" style="-fx-font-weight: bold;"/>
            <Slider fx:id="sliderZoom" prefWidth="200" min="0.25" max="3.0" value="1.0" showTickMarks="true" showTickLabels="true" majorTickUnit="0.5"/>
            <Label fx:id="lblZoomValue" text="100%" style="-fx-min-width: 50;"/>
         </HBox>
         
      </VBox>
   </top>
   
   <!-- CONTENU PRINCIPAL -->
   <center>
      <SplitPane dividerPositions="0.65">
         
         <!-- ZONE GRAPHE -->
         <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #ecf0f1;">
            
            <!-- Légende -->
            <HBox spacing="30" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 8;">
               <Label fx:id="lblModeActif" text="📊 MODE: VUE COLLECTIVE" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #3498db;"/>
               <Separator orientation="VERTICAL" prefHeight="20"/>
               <HBox spacing="8" alignment="CENTER">
                  <Region prefWidth="30" prefHeight="5" style="-fx-background-color: #e67e22; -fx-background-radius: 3;"/>
                  <Label text="Entrants" style="-fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
               </HBox>
               <HBox spacing="8" alignment="CENTER">
                  <Region prefWidth="30" prefHeight="5" style="-fx-background-color: #3498db; -fx-background-radius: 3;"/>
                  <Label text="Sortants" style="-fx-font-weight: bold; -fx-text-fill: #3498db;"/>
               </HBox>
               <HBox spacing="8" alignment="CENTER">
                  <Region prefWidth="30" prefHeight="5" style="-fx-background-color: #95a5a6; -fx-background-radius: 3;"/>
                  <Label text="Internes" style="-fx-font-weight: bold; -fx-text-fill: #95a5a6;"/>
               </HBox>
               <Separator orientation="VERTICAL" prefHeight="20"/>
               <HBox spacing="5">
                  <Label text="⚠️"/>
                  <Label text="Goulot" style="-fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
               </HBox>
            </HBox>
            
            <!-- Zone de dessin -->
            <ScrollPane fx:id="graphScrollPane" fitToWidth="false" fitToHeight="false" pannable="true" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 8;">
               <Pane fx:id="graphPane" style="-fx-background-color: #f8f9fa;"/>
            </ScrollPane>
            
            <!-- Info -->
            <HBox spacing="10" style="-fx-background-color: #d5e8f7; -fx-padding: 10; -fx-background-radius: 6;">
               <Label text="💡"/>
               <VBox spacing="2">
                  <Label fx:id="lblInfo1" text="• Survolez les nœuds pour voir les détails des services" style="-fx-font-size: 11px;"/>
                  <Label fx:id="lblInfo2" text="• La largeur des flèches = volume de courriers" style="-fx-font-size: 11px;"/>
                  <Label fx:id="lblInfo3" text="• Ctrl + Molette pour zoomer" style="-fx-font-size: 11px;"/>
               </VBox>
            </HBox>
         </VBox>
         
         <!-- PANNEAU STATISTIQUES AVEC SCROLLBAR -->
         <ScrollPane fitToWidth="true" style="-fx-background-color: white; -fx-border-color: transparent;">
            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20;">
               
               <Label fx:id="lblStatsTitre" text="📈 STATISTIQUES EN TEMPS RÉEL" 
                      style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #2c3e50;"/>
               
               <Separator/>
               
               <!-- Stats globales / individuelles -->
               <GridPane hgap="10" vgap="10">
                  <columnConstraints>
                     <ColumnConstraints percentWidth="50"/>
                     <ColumnConstraints percentWidth="50"/>
                  </columnConstraints>
                  
                  <VBox alignment="CENTER" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0"
                        style="-fx-background-color: #e8f4f8; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #3498db; -fx-border-width: 2; -fx-border-radius: 8;">
                     <Label text="📧" style="-fx-font-size: 28px;"/>
                     <Label fx:id="statTotalCourriers" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                     <Label fx:id="statTotalCourrierLabel" text="Courriers" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                  </VBox>
                  
                  <VBox alignment="CENTER" spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0"
                        style="-fx-background-color: #f5eef8; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #9b59b6; -fx-border-width: 2; -fx-border-radius: 8;">
                     <Label text="🏢" style="-fx-font-size: 28px;"/>
                     <Label fx:id="statServicesActifs" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;"/>
                     <Label fx:id="statServicesLabel" text="Services" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                  </VBox>
                  
                  <VBox alignment="CENTER" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1"
                        style="-fx-background-color: #fef5e7; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #f39c12; -fx-border-width: 2; -fx-border-radius: 8;">
                     <Label text="⏱️" style="-fx-font-size: 28px;"/>
                     <Label fx:id="statDureeMoyenne" text="0h" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                     <Label fx:id="statDureeLabel" text="Durée moy." style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                  </VBox>
                  
                  <VBox alignment="CENTER" spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1"
                        style="-fx-background-color: #fdeaea; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e74c3c; -fx-border-width: 2; -fx-border-radius: 8;">
                     <Label text="⚠️" style="-fx-font-size: 28px;"/>
                     <Label fx:id="statGoulotsDetectes" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                     <Label fx:id="statGoulotsLabel" text="Goulots" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                  </VBox>
               </GridPane>
               
               <Separator/>
               
               <!-- Détails par service OU Chronologie du courrier -->
               <VBox fx:id="statsDetailContainer" spacing="10" VBox.vgrow="ALWAYS">
                  <Label fx:id="lblDetailsTitle" text="📋 DÉTAILS PAR SERVICE" 
                         style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                  
                  <!-- Table (mode collectif) -->
                  <TableView fx:id="tableFluxDetails" prefHeight="400" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colService" text="Service" prefWidth="120"/>
                        <TableColumn fx:id="colEntrants" text="↓" prefWidth="40" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colSortants" text="↑" prefWidth="40" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colInternes" text="↔" prefWidth="40" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colDuree" text="Durée" prefWidth="70" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colStatut" text="Statut" prefWidth="90"/>
                     </columns>
                     
                     <placeholder>
                        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 30;">
                           <Label text="📊" style="-fx-font-size: 36px; -fx-text-fill: #bdc3c7;"/>
                           <Label text="Aucune donnée" style="-fx-text-fill: #7f8c8d;"/>
                        </VBox>
                     </placeholder>
                  </TableView>
                  
                  <!-- Chronologie (mode individuel) - caché par défaut -->
                  <VBox fx:id="chronologieContainer" spacing="5" visible="false" managed="false" style="-fx-padding: 10;"/>
                  
               </VBox>
               
            </VBox>
         </ScrollPane>
         
      </SplitPane>
   </center>
   
   <!-- BARRE DE STATUS -->
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #34495e; -fx-padding: 8 20;">
         <Label fx:id="lblStatus" text="ℹ️ Sélectionnez un mode de visualisation" style="-fx-text-fill: white; -fx-font-size: 11px;"/>
         <Region HBox.hgrow="ALWAYS"/>
         <Label fx:id="lblNbEtapes" text="" style="-fx-text-fill: #bdc3c7; -fx-font-size: 10px;"/>
      </HBox>
   </bottom>
   
</BorderPane>
