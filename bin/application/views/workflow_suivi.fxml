<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="application.controllers.WorkflowSuiviController"
            style="-fx-background-color: #f5f6fa;">
   
   <!-- Barre supérieure -->
   <top>
      <VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
         
         <!-- En-tête -->
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 24px;" 
                   text="📊 Dashboard Workflow - Suivi des Courriers" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleActualiser" 
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5; -fx-padding: 10 20;" 
                    text="🔄 Actualiser" />
         </HBox>
         
         <!-- Statistiques -->
         <GridPane hgap="15.0" vgap="10.0">
            <columnConstraints>
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
            </columnConstraints>
            
            <!-- Total courriers -->
            <VBox alignment="CENTER" spacing="8.0" GridPane.columnIndex="0"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #3498db; -fx-border-width: 2; -fx-border-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label style="-fx-font-size: 36px;" text="📧" />
               <Label fx:id="statTotal" 
                      style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #3498db;" 
                      text="0" />
               <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px; -fx-font-weight: 600;" 
                      text="Total courriers" />
            </VBox>
            
            <!-- En cours -->
            <VBox alignment="CENTER" spacing="8.0" GridPane.columnIndex="1"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #f39c12; -fx-border-width: 2; -fx-border-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label style="-fx-font-size: 36px;" text="⏳" />
               <Label fx:id="statEnCours" 
                      style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" 
                      text="0" />
               <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px; -fx-font-weight: 600;" 
                      text="En cours" />
            </VBox>
            
            <!-- Terminés -->
            <VBox alignment="CENTER" spacing="8.0" GridPane.columnIndex="2"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #27ae60; -fx-border-width: 2; -fx-border-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label style="-fx-font-size: 36px;" text="✅" />
               <Label fx:id="statTermines" 
                      style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" 
                      text="0" />
               <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px; -fx-font-weight: 600;" 
                      text="Terminés" />
            </VBox>
            
            <!-- En attente (au lieu de "En retard") -->
            <VBox alignment="CENTER" spacing="8.0" GridPane.columnIndex="3"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #e74c3c; -fx-border-width: 2; -fx-border-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label style="-fx-font-size: 36px;" text="⏰" />
               <Label fx:id="statEnAttente" 
                      style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" 
                      text="0" />
               <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px; -fx-font-weight: 600;" 
                      text="En attente" />
            </VBox>
         </GridPane>
         
         <!-- Filtres -->
         <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 10 0;">
            <Label style="-fx-text-fill: #7f8c8d; -fx-font-weight: 600;" text="Filtrer par:" />
            <ComboBox fx:id="filtreService" prefWidth="180.0" promptText="Service"
                     style="-fx-background-radius: 5;" />
            <ComboBox fx:id="filtreStatut" prefWidth="150.0" promptText="Statut"
                     style="-fx-background-radius: 5;" />
            <ComboBox fx:id="filtrePriorite" prefWidth="150.0" promptText="Priorité"
                     style="-fx-background-radius: 5;" />
            
            <Region HBox.hgrow="ALWAYS" />
            
            <TextField fx:id="champRecherche" prefWidth="250.0" promptText="🔍 Rechercher..."
                      style="-fx-background-radius: 5;" />
            <Button text="🔄 Réinitialiser" onAction="#handleReinitialiserFiltres"
                   style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5; -fx-padding: 8 16;" />
         </HBox>
         
      </VBox>
   </top>
   
   <!-- Zone principale -->
   <center>
      <SplitPane dividerPositions="0.6" orientation="HORIZONTAL" style="-fx-background-color: #f5f6fa;">
         
         <!-- Liste des courriers -->
         <VBox spacing="10.0" style="-fx-padding: 20;">
            
            <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;" 
                   text="Liste des courriers en workflow" />
            
            <TableView fx:id="tableWorkflow" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <columns>
                  <TableColumn fx:id="colNumero" prefWidth="120.0" text="N° Courrier" 
                              style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colObjet" prefWidth="250.0" text="Objet" />
                  <TableColumn fx:id="colStatut" prefWidth="120.0" text="Statut" 
                              style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colService" prefWidth="160.0" text="Service actuel" />
                  <TableColumn fx:id="colPriorite" prefWidth="120.0" text="Priorité" 
                              style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colDate" prefWidth="140.0" text="Date" 
                              style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colActions" prefWidth="80.0" text="Actions" 
                              style="-fx-alignment: CENTER;" />
               </columns>
               
               <placeholder>
                  <VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 50;">
                     <Label style="-fx-font-size: 64px; -fx-text-fill: #bdc3c7;" text="📭" />
                     <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 18px; -fx-font-weight: 600;" 
                            text="Aucun courrier en workflow" />
                     <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 13px;" 
                            text="Les courriers apparaîtront ici une fois qu'ils seront en traitement" />
                  </VBox>
               </placeholder>
            </TableView>
            
         </VBox>
         
         <!-- Panneau de détails -->
         <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox fx:id="detailsContainer" spacing="20.0" style="-fx-padding: 20;">
               
               <!-- Titre -->
               <VBox spacing="10.0">
                  <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #2c3e50;" 
                         text="📄 Détails du courrier" />
                  <Label fx:id="labelCourrierSelectionne" 
                         style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" 
                         text="Sélectionnez un courrier pour voir son workflow" 
                         wrapText="true" />
               </VBox>
               
               <Separator />
               
               <!-- Informations principales -->
               <VBox spacing="15.0" 
                     style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" 
                         text="Informations générales" />
                  
                  <GridPane hgap="15.0" vgap="12.0">
                     <columnConstraints>
                        <ColumnConstraints percentWidth="35.0" />
                        <ColumnConstraints percentWidth="65.0" />
                     </columnConstraints>
                     
                     <Label text="N° Courrier:" GridPane.columnIndex="0" GridPane.rowIndex="0" 
                            style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
                     <Label fx:id="detailNumero" text="--" GridPane.columnIndex="1" GridPane.rowIndex="0"
                            style="-fx-text-fill: #2c3e50;"/>
                     
                     <Label text="Objet:" GridPane.columnIndex="0" GridPane.rowIndex="1" 
                            style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
                     <Label fx:id="detailObjet" text="--" GridPane.columnIndex="1" GridPane.rowIndex="1" 
                            wrapText="true" style="-fx-text-fill: #2c3e50;"/>
                     
                     <Label text="Statut:" GridPane.columnIndex="0" GridPane.rowIndex="2" 
                            style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
                     <Label fx:id="detailStatut" text="--" GridPane.columnIndex="1" GridPane.rowIndex="2"
                            style="-fx-text-fill: #2c3e50;"/>
                     
                     <Label text="Priorité:" GridPane.columnIndex="0" GridPane.rowIndex="3" 
                            style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
                     <Label fx:id="detailPriorite" text="--" GridPane.columnIndex="1" GridPane.rowIndex="3"
                            style="-fx-text-fill: #2c3e50;"/>
                     
                     <Label text="Expéditeur:" GridPane.columnIndex="0" GridPane.rowIndex="4" 
                            style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
                     <Label fx:id="detailExpediteur" text="--" GridPane.columnIndex="1" GridPane.rowIndex="4"
                            style="-fx-text-fill: #2c3e50;"/>
                     
                     <Label text="Date réception:" GridPane.columnIndex="0" GridPane.rowIndex="5" 
                            style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
                     <Label fx:id="detailDateReception" text="--" GridPane.columnIndex="1" GridPane.rowIndex="5"
                            style="-fx-text-fill: #2c3e50;"/>
                     
                     <Label text="Service actuel:" GridPane.columnIndex="0" GridPane.rowIndex="6" 
                            style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
                     <Label fx:id="detailServiceActuel" text="--" GridPane.columnIndex="1" GridPane.rowIndex="6"
                            style="-fx-text-fill: #2c3e50;"/>
                  </GridPane>
               </VBox>
               
               <!-- Timeline du workflow -->
               <VBox spacing="10.0" 
                     style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 16px;" 
                         text="⏱️ Timeline du workflow" />
                  
                  <ScrollPane fx:id="workflowPane" fitToWidth="true" prefHeight="300" VBox.vgrow="ALWAYS"
                             style="-fx-background-color: transparent; -fx-border-width: 0; -fx-background: transparent;">
                     <VBox fx:id="timelineContainer" spacing="10.0">
                        <!-- Timeline sera construite dynamiquement -->
                        <VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 40;">
                           <Label style="-fx-font-size: 48px; -fx-text-fill: #bdc3c7;" text="🔄" />
                           <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" 
                                  text="Sélectionnez un courrier dans la liste" />
                           <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 12px;" 
                                  text="pour visualiser sa chaîne de workflow" />
                        </VBox>
                     </VBox>
                  </ScrollPane>
                  
                  <!-- Légende -->
                  <Separator />
                  <VBox spacing="8.0">
                     <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" 
                            text="Légende" />
                     
                     <HBox spacing="20.0">
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                           <Label style="-fx-font-size: 14px;" text="🔵" />
                           <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Étape en cours" />
                        </HBox>
                        
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                           <Label style="-fx-font-size: 14px;" text="🟢" />
                           <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Étape terminée" />
                        </HBox>
                        
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                           <Label style="-fx-font-size: 14px;" text="⚪" />
                           <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Étape en attente" />
                        </HBox>
                     </HBox>
                  </VBox>
               </VBox>
               
               <!-- Actions rapides -->
               <VBox spacing="10.0" 
                     style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 16px;" 
                         text="⚡ Actions rapides" />
                  
                  <HBox spacing="10.0">
                     <Button fx:id="btnTransferer" text="➡️ Transférer" onAction="#handleTransferer"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5; -fx-padding: 10 20;"/>
                     <Button fx:id="btnTraiter" text="✅ Traiter" onAction="#handleTraiter"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5; -fx-padding: 10 20;"/>
                  </HBox>
                  
                  <HBox spacing="10.0">
                     <Button fx:id="btnArchiver" text="📦 Archiver" onAction="#handleArchiver"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5; -fx-padding: 10 20;"/>
                     <Button fx:id="btnAjouterCommentaire" text="💬 Commenter" onAction="#handleAjouterCommentaire"
                            style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5; -fx-padding: 10 20;"/>
                  </HBox>
               </VBox>
               
               <!-- Zone de commentaire -->
               <VBox spacing="8.0" 
                     style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" 
                         text="Commentaire:" />
                  <TextArea fx:id="detailCommentaire" prefRowCount="4" wrapText="true"
                           promptText="Ajoutez un commentaire sur ce courrier..."
                           style="-fx-background-radius: 5;"/>
               </VBox>
               
            </VBox>
         </ScrollPane>
         
      </SplitPane>
   </center>
   
</BorderPane>
