<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane 
    xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" 
    fx:controller="application.controllers.DashboardController"
    styleClass="main-container" 
    fitToWidth="true" 
    fitToHeight="true" 
    style="-fx-background-color: #f5f6fa;">

   <content>
      <VBox spacing="20.0" style="-fx-padding: 30; -fx-background-color: #f5f6fa;" 
            maxWidth="Infinity" maxHeight="Infinity" minWidth="800" minHeight="600" prefWidth="1000" prefHeight="700" VBox.vgrow="ALWAYS">
         
         <!-- En-tête du dashboard -->
         <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header-bar responsive-header" 
               style="-fx-padding: 20; -fx-background-radius: 10;">
            <Label styleClass="header-title" style="-fx-text-fill: white;" 
                   text="📊 Tableau de Bord - Suivi des Workflows">
               <font>
                  <Font size="28.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="10" styleClass="header-actions">
               <Button fx:id="btnActualiser" onAction="#handleActualiser" 
                       styleClass="button-secondary" text="🔄 Actualiser" />
               <Button styleClass="button-info" text="📊 Rapport" />
            </HBox>
         </HBox>
         
         <!-- Cartes de statistiques principales - RESPONSIVE avec FlowPane -->
         <FlowPane fx:id="statsFlowPane" hgap="20.0" vgap="20.0" 
                   alignment="CENTER" prefWrapLength="1200" 
                   styleClass="stats-container">
            
            <!-- Carte Courriers en attente -->
            <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card stat-card-responsive" 
                  minWidth="200" prefWidth="250" maxWidth="350">
               <Label style="-fx-font-size: 36px;" text="📧" />
               <Label fx:id="statCourriersEnAttente" styleClass="stat-value" 
                      style="-fx-text-fill: #e74c3c;" text="0" />
               <Label styleClass="stat-label" text="Courriers en attente" />
               <Label fx:id="trendCourriers" styleClass="stat-trend" text="↗ +5 aujourd'hui" />
            </VBox>
            
            <!-- Carte Documents actifs -->
            <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card stat-card-responsive" 
                  minWidth="200" prefWidth="250" maxWidth="350">
               <Label style="-fx-font-size: 36px;" text="📄" />
               <Label fx:id="statDocumentsActifs" styleClass="stat-value" 
                      style="-fx-text-fill: #3498db;" text="0" />
               <Label styleClass="stat-label" text="Documents actifs" />
               <Label fx:id="trendDocuments" styleClass="stat-trend" text="↗ +12 cette semaine" />
            </VBox>
            
            <!-- Carte Réunions -->
            <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card stat-card-responsive" 
                  minWidth="200" prefWidth="250" maxWidth="350">
               <Label style="-fx-font-size: 36px;" text="👥" />
               <Label fx:id="statReunionsMois" styleClass="stat-value" 
                      style="-fx-text-fill: #f39c12;" text="0" />
               <Label styleClass="stat-label" text="Réunions ce mois" />
               <Label style="-fx-text-fill: #7f8c8d;" text="→ 3 à venir" />
            </VBox>
            
            <!-- Carte Messages non lus -->
            <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card stat-card-responsive" 
                  minWidth="200" prefWidth="250" maxWidth="350">
               <Label style="-fx-font-size: 36px;" text="💬" />
               <Label fx:id="statMessagesNonLus" styleClass="stat-value" 
                      style="-fx-text-fill: #27ae60;" text="0" />
               <Label styleClass="stat-label" text="Messages non lus" />
               <Label style="-fx-text-fill: #7f8c8d;" text="↘ -8 depuis hier" />
            </VBox>
         </FlowPane>
         
         <!-- Section Workflow -->
         <VBox spacing="15.0" styleClass="section-card responsive-workflow" 
               style="-fx-padding: 20;" maxWidth="Infinity" VBox.vgrow="ALWAYS">
            
            <!-- En-tête workflow - Responsive -->
            <VBox spacing="15">
               <HBox alignment="CENTER_LEFT" spacing="15.0">
                  <Label styleClass="section-title" text="🔄 Workflow des Courriers" />
                  <Region HBox.hgrow="ALWAYS" />
               </HBox>
               
               <!-- Statistiques workflow - Responsive FlowPane -->
               <FlowPane fx:id="workflowStatsFlow" hgap="15" vgap="10" 
                         alignment="CENTER_LEFT" prefWrapLength="800">
                  
                  <VBox alignment="CENTER" spacing="3" minWidth="120" styleClass="workflow-stat-box">
                     <Label styleClass="workflow-stat-label" text="Service actuel" />
                     <Label fx:id="labelServiceActuel" styleClass="workflow-stat-value" 
                            style="-fx-text-fill: #3498db;" text="--" />
                  </VBox>
                  
                  <Separator orientation="VERTICAL" prefHeight="40" managed="false" 
                            styleClass="workflow-separator" />
                  
                  <VBox alignment="CENTER" spacing="3" minWidth="120" styleClass="workflow-stat-box">
                     <Label styleClass="workflow-stat-label" text="En cours" />
                     <Label fx:id="labelCourriersEnCours" styleClass="workflow-stat-value" 
                            style="-fx-text-fill: #f39c12;" text="0" />
                  </VBox>
                  
                  <Separator orientation="VERTICAL" prefHeight="40" managed="false" 
                            styleClass="workflow-separator" />
                  
                  <VBox alignment="CENTER" spacing="3" minWidth="120" styleClass="workflow-stat-box">
                     <Label styleClass="workflow-stat-label" text="En retard" />
                     <Label fx:id="labelCourriersEnRetard" styleClass="workflow-stat-value" 
                            style="-fx-text-fill: #e74c3c;" text="0" />
                  </VBox>
               </FlowPane>
            </VBox>
            
            <Separator />
            
            <!-- Container pour les courriers en workflow -->
            <ScrollPane fx:id="workflowScrollPane" fitToWidth="true" 
                       prefHeight="400" minHeight="200"
                       style="-fx-background-color: transparent; -fx-border-width: 0;"
                       styleClass="workflow-scroll">
               <VBox fx:id="workflowContainer" spacing="15.0" style="-fx-padding: 10;">
                  <!-- Les courriers seront ajoutés dynamiquement ici -->
                  <VBox alignment="CENTER" spacing="20" style="-fx-padding: 50;">
                     <Label style="-fx-font-size: 48px; -fx-text-fill: #bdc3c7;" text="🔄" />
                     <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 16px;" 
                            text="Aucun courrier en workflow actuellement" />
                     <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 12px;" 
                            text="Les courriers apparaîtront ici une fois qu'ils seront en traitement" />
                  </VBox>
               </VBox>
            </ScrollPane>
         </VBox>
         
         <!-- Graphiques et analyses - RESPONSIVE -->
         <VBox fx:id="chartsContainer" spacing="20" VBox.vgrow="ALWAYS">
            
            <!-- Ligne 1 : Graphique d'évolution et Répartition -->
            <HBox fx:id="chartsRow1" spacing="20" styleClass="charts-row">
               
               <!-- Graphique d'évolution -->
               <VBox spacing="15.0" styleClass="section-card chart-card" 
                     style="-fx-padding: 20;" minWidth="300" HBox.hgrow="ALWAYS">
                  <Label styleClass="section-title" text="Évolution mensuelle" />
                  <LineChart fx:id="evolutionChart" prefHeight="250.0" minHeight="200">
                     <xAxis>
                        <CategoryAxis side="BOTTOM" />
                     </xAxis>
                     <yAxis>
                        <NumberAxis side="LEFT" />
                     </yAxis>
                  </LineChart>
               </VBox>
               
               <!-- Répartition par statut -->
               <VBox spacing="15.0" styleClass="section-card chart-card" 
                     style="-fx-padding: 20;" minWidth="250" HBox.hgrow="ALWAYS">
                  <Label styleClass="section-title" text="Répartition des courriers" />
                  <PieChart fx:id="repartitionChart" prefHeight="250.0" minHeight="200" />
               </VBox>
            </HBox>
            
            <!-- Ligne 2 : Activités récentes et Indicateurs -->
            <HBox fx:id="chartsRow2" spacing="20" styleClass="charts-row">
               
               <!-- Activités récentes -->
               <VBox spacing="15.0" styleClass="section-card" 
                     style="-fx-padding: 20;" minWidth="300" HBox.hgrow="ALWAYS">
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <Label styleClass="section-title" text="Activités récentes" />
                     <Region HBox.hgrow="ALWAYS" />
                     <Hyperlink text="Voir tout" />
                  </HBox>
                  
                  <ScrollPane fitToWidth="true" prefHeight="200" minHeight="150"
                             style="-fx-background-color: transparent;">
                     <VBox fx:id="activitesRecentesContainer" spacing="10.0">
                        <!-- Les activités seront ajoutées dynamiquement -->
                     </VBox>
                  </ScrollPane>
               </VBox>
               
               <!-- Indicateurs de performance -->
               <VBox spacing="15.0" styleClass="section-card" 
                     style="-fx-padding: 20;" minWidth="250" HBox.hgrow="ALWAYS">
                  <Label styleClass="section-title" text="Indicateurs de performance" />
                  
                  <VBox spacing="15.0">
                     <!-- Taux de traitement -->
                     <VBox spacing="5.0">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <Label text="Taux de traitement" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label fx:id="tauxTraitementLabel" 
                                  style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" 
                                  text="87%" />
                        </HBox>
                        <ProgressBar fx:id="tauxTraitementBar" prefWidth="Infinity" 
                                    maxWidth="Infinity" progress="0.87" />
                     </VBox>
                     
                     <!-- Délai moyen -->
                     <VBox spacing="5.0">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <Label text="Délai moyen traitement" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label fx:id="delaiMoyenLabel" 
                                  style="-fx-font-weight: bold; -fx-text-fill: #f39c12;" 
                                  text="2.3j" />
                        </HBox>
                        <ProgressBar fx:id="delaiMoyenBar" prefWidth="Infinity" 
                                    maxWidth="Infinity" progress="0.65" />
                     </VBox>
                     
                     <!-- Satisfaction -->
                     <VBox spacing="5.0">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <Label text="Satisfaction utilisateur" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" 
                                  text="92%" />
                        </HBox>
                        <ProgressBar prefWidth="Infinity" maxWidth="Infinity" progress="0.92" />
                     </VBox>
                     
                     <!-- Utilisation système -->
                     <VBox spacing="5.0">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <Label text="Utilisation système" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label style="-fx-font-weight: bold; -fx-text-fill: #3498db;" 
                                  text="76%" />
                        </HBox>
                        <ProgressBar prefWidth="Infinity" maxWidth="Infinity" progress="0.76" />
                     </VBox>
                  </VBox>
                  
                  <!-- Actions rapides -->
                  <Separator />
                  <Label style="-fx-font-weight: bold;" text="Actions rapides" />
                  <VBox spacing="8.0">
                     <Button maxWidth="Infinity" styleClass="button-primary" 
                            text="📊 Générer rapport mensuel" />
                     <Button maxWidth="Infinity" styleClass="button-info" 
                            text="📈 Analyser tendances" />
                     <Button maxWidth="Infinity" styleClass="button-warning" 
                            text="⚠️ Alertes système" />
                  </VBox>
               </VBox>
            </HBox>
         </VBox>
         
      </VBox>
   </content>
</ScrollPane>
