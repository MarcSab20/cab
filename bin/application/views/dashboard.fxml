<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <content>
      <VBox spacing="20.0" style="-fx-padding: 30;">
         
         <!-- En-tête du dashboard -->
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;" text="Tableau de Bord">
               <font>
                  <Font size="28.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button styleClass="button-primary" text="🔄 Actualiser" />
            <Button styleClass="button-secondary" text="📊 Rapport" />
         </HBox>
         
         <!-- Cartes de statistiques principales -->
         <GridPane hgap="20.0" vgap="20.0">
            <columnConstraints>
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
               <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
            </columnConstraints>
            
            <!-- Carte Courriers -->
            <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card" GridPane.columnIndex="0">
               <Label style="-fx-font-size: 36px;" text="📧" />
               <Label styleClass="stat-number" style="-fx-text-fill: #e74c3c;" text="23" />
               <Label styleClass="stat-label" text="Courriers en attente" />
               <Label styleClass="stat-trend-up" text="↗ +5 aujourd'hui" />
            </VBox>
            
            <!-- Carte Documents -->
            <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card" GridPane.columnIndex="1">
               <Label style="-fx-font-size: 36px;" text="📄" />
               <Label styleClass="stat-number" style="-fx-text-fill: #3498db;" text="156" />
               <Label styleClass="stat-label" text="Documents actifs" />
               <Label styleClass="stat-trend-up" text="↗ +12 cette semaine" />
            </VBox>
            
            <!-- Carte Réunions -->
            <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card" GridPane.columnIndex="2">
               <Label style="-fx-font-size: 36px;" text="👥" />
               <Label styleClass="stat-number" style="-fx-text-fill: #f39c12;" text="7" />
               <Label styleClass="stat-label" text="Réunions ce mois" />
               <Label style="-fx-text-fill: #7f8c8d;" text="→ 3 à venir" />
            </VBox>
            
            <!-- Carte Messages -->
            <VBox alignment="CENTER" spacing="10.0" styleClass="stat-card" GridPane.columnIndex="3">
               <Label style="-fx-font-size: 36px;" text="💬" />
               <Label styleClass="stat-number" style="-fx-text-fill: #27ae60;" text="45" />
               <Label styleClass="stat-label" text="Messages non lus" />
               <Label styleClass="stat-trend-down" text="↘ -8 depuis hier" />
            </VBox>
         </GridPane>
         
         <!-- Graphiques et analyses -->
         <GridPane hgap="20.0" vgap="20.0">
            <columnConstraints>
               <ColumnConstraints hgrow="ALWAYS" percentWidth="60.0" />
               <ColumnConstraints hgrow="ALWAYS" percentWidth="40.0" />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints vgrow="ALWAYS" />
               <RowConstraints vgrow="ALWAYS" />
            </rowConstraints>
            
            <!-- Graphique d'évolution -->
            <VBox spacing="15.0" styleClass="card" GridPane.columnIndex="0" GridPane.rowIndex="0">
               <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Évolution mensuelle" />
               <LineChart fx:id="evolutionChart" prefHeight="250.0">
                  <xAxis>
                     <CategoryAxis side="BOTTOM" />
                  </xAxis>
                  <yAxis>
                     <NumberAxis side="LEFT" />
                  </yAxis>
               </LineChart>
            </VBox>
            
            <!-- Répartition par type -->
            <VBox spacing="15.0" styleClass="card" GridPane.columnIndex="1" GridPane.rowIndex="0">
               <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Répartition des documents" />
               <PieChart fx:id="repartitionChart" prefHeight="250.0" />
            </VBox>
            
            <!-- Activités récentes -->
            <VBox spacing="15.0" styleClass="card" GridPane.columnIndex="0" GridPane.rowIndex="1">
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Activités récentes" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Hyperlink text="Voir tout" />
               </HBox>
               
               <VBox spacing="10.0">
                  <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-background-radius: 5;">
                     <Label style="-fx-font-size: 16px;" text="📧" />
                     <VBox HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-weight: bold;" text="Courrier urgent reçu" />
                        <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Contrat Client XYZ - Réponse requise" />
                     </VBox>
                     <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="Il y a 5 min" />
                  </HBox>
                  
                  <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-background-radius: 5;">
                     <Label style="-fx-font-size: 16px;" text="📄" />
                     <VBox HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-weight: bold;" text="Document validé" />
                        <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Rapport financier Q4 2024" />
                     </VBox>
                     <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="Il y a 15 min" />
                  </HBox>
                  
                  <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-background-radius: 5;">
                     <Label style="-fx-font-size: 16px;" text="👥" />
                     <VBox HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-weight: bold;" text="Réunion planifiée" />
                        <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Revue projet - Demain 10h00" />
                     </VBox>
                     <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="Il y a 1h" />
                  </HBox>
                  
                  <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-background-radius: 5;">
                     <Label style="-fx-font-size: 16px;" text="💬" />
                     <VBox HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-weight: bold;" text="Message important" />
                        <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="De: Direction - Nouvelle procédure" />
                     </VBox>
                     <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" text="Il y a 2h" />
                  </HBox>
               </VBox>
            </VBox>
            
            <!-- Indicateurs de performance -->
            <VBox spacing="15.0" styleClass="card" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Indicateurs de performance" />
               
               <VBox spacing="15.0">
                  <!-- Taux de traitement -->
                  <VBox spacing="5.0">
                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Taux de traitement courrier" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" text="87%" />
                     </HBox>
                     <ProgressBar prefWidth="200.0" progress="0.87" styleClass="progress-bar" />
                  </VBox>
                  
                  <!-- Délai moyen -->
                  <VBox spacing="5.0">
                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Délai moyen traitement" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #f39c12;" text="2.3j" />
                     </HBox>
                     <ProgressBar prefWidth="200.0" progress="0.65" styleClass="progress-bar" />
                  </VBox>
                  
                  <!-- Satisfaction -->
                  <VBox spacing="5.0">
                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Satisfaction utilisateur" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" text="92%" />
                     </HBox>
                     <ProgressBar prefWidth="200.0" progress="0.92" styleClass="progress-bar" />
                  </VBox>
                  
                  <!-- Utilisation système -->
                  <VBox spacing="5.0">
                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Utilisation système" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3498db;" text="76%" />
                     </HBox>
                     <ProgressBar prefWidth="200.0" progress="0.76" styleClass="progress-bar" />
                  </VBox>
               </VBox>
               
               <!-- Actions rapides -->
               <Separator />
               <Label style="-fx-font-weight: bold;" text="Actions rapides" />
               <VBox spacing="8.0">
                  <Button maxWidth="1.7976931348623157E308" styleClass="button-primary" text="📊 Générer rapport mensuel" />
                  <Button maxWidth="1.7976931348623157E308" styleClass="button-info" text="📈 Analyser tendances" />
                  <Button maxWidth="1.7976931348623157E308" styleClass="button-warning" text="⚠️ Alertes système" />
               </VBox>
            </VBox>
         </GridPane>
         
         <!-- Alertes et notifications -->
         <VBox spacing="15.0" styleClass="card">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="⚠️ Alertes et notifications" />
            
            <VBox spacing="10.0">
               <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="alert-warning">
                  <Label style="-fx-font-size: 16px;" text="⚠️" />
                  <VBox HBox.hgrow="ALWAYS">
                     <Label style="-fx-font-weight: bold;" text="5 courriers urgents en attente" />
                     <Label style="-fx-font-size: 12px;" text="Délai de traitement dépassé pour certains dossiers" />
                  </VBox>
                  <Button styleClass="button-warning" text="Traiter" />
               </HBox>
               
               <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="alert-info">
                  <Label style="-fx-font-size: 16px;" text="ℹ️" />
                  <VBox HBox.hgrow="ALWAYS">
                     <Label style="-fx-font-weight: bold;" text="Sauvegarde programmée ce soir" />
                     <Label style="-fx-font-size: 12px;" text="Maintenance système prévue de 22h à 23h" />
                  </VBox>
                  <Button styleClass="button-info" text="Détails" />
               </HBox>
               
               <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="alert-success">
                  <Label style="-fx-font-size: 16px;" text="✅" />
                  <VBox HBox.hgrow="ALWAYS">
                     <Label style="-fx-font-weight: bold;" text="Objectif mensuel atteint" />
                     <Label style="-fx-font-size: 12px;" text="87% des courriers traités dans les délais" />
                  </VBox>
               </HBox>
            </VBox>
         </VBox>
         
      </VBox>
   </content>
</ScrollPane>