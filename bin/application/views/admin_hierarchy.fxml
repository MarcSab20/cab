<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.controllers.AdminHierarchyController"
            styleClass="main-container">
    
    <!-- En-tête -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-bar">
                <padding>
                    <Insets top="15" right="20" bottom="15" left="20"/>
                </padding>
                
                <Label text="⚙️ Administration - Hiérarchie des Services" styleClass="header-title"/>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <Button text="🔄 Actualiser" onAction="#handleRefresh" styleClass="button-secondary"/>
                <Button text="📤 Exporter" onAction="#handleExportHierarchy" styleClass="button-info"/>
                <Button text="📥 Importer" onAction="#handleImportHierarchy" styleClass="button-info"/>
            </HBox>
            
            <!-- Statistiques rapides -->
            <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: #f8f9fa; -fx-padding: 15 20 15 20;">
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Total Services" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                    <Label fx:id="statTotalServices" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                </VBox>
                
                <Separator orientation="VERTICAL" prefHeight="40"/>
                
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Services Actifs" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                    <Label fx:id="statServicesActifs" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </VBox>
                
                <Separator orientation="VERTICAL" prefHeight="40"/>
                
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Niveaux Hiérarchiques" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                    <Label fx:id="statNiveaux" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>
    
    <!-- Contenu principal -->
    <center>
        <SplitPane dividerPositions="0.3, 0.7" orientation="HORIZONTAL">
            
            <!-- Panel gauche: Arbre hiérarchique -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15;">
                <Label text="🌳 Arbre Hiérarchique" styleClass="section-title"/>
                
                <Separator/>
                
                <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS">
                    <TreeView fx:id="hierarchyTreeView" VBox.vgrow="ALWAYS"/>
                </ScrollPane>
                
                <Button text="📊 Visualiser la structure" onAction="#handleShowVisualization" 
                        styleClass="button-primary" maxWidth="Infinity"/>
            </VBox>
            
            <!-- Panel central: Tableau des services -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15;">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="📋 Liste des Services" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="➕ Nouveau Service" onAction="#handleNewService" styleClass="button-success"/>
                </HBox>
                
                <Separator/>
                
                <!-- Barre de recherche et filtres -->
                <VBox spacing="10">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="🔍 Recherche:"/>
                        <TextField fx:id="tfSearch" promptText="Code ou nom du service..." 
                                 HBox.hgrow="ALWAYS" prefWidth="200"/>
                        <Button text="Rechercher" onAction="#handleSearch" styleClass="button-primary"/>
                    </HBox>
                    
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="Filtres:"/>
                        <ComboBox fx:id="cbFilterNiveau" promptText="Niveau..." prefWidth="250"/>
                        <CheckBox fx:id="chkFilterActifs" text="Uniquement les actifs" selected="true"/>
                        <Button text="Réinitialiser" onAction="#handleClearFilters" styleClass="button-secondary"/>
                    </HBox>
                </VBox>
                
                <Separator/>
                
                <!-- Tableau -->
                <TableView fx:id="servicesTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colServiceCode" text="Code" prefWidth="100" minWidth="80"/>
                        <TableColumn fx:id="colServiceName" text="Nom du Service" prefWidth="250" minWidth="150"/>
                        <TableColumn fx:id="colParent" text="Service Parent" prefWidth="120" minWidth="100"/>
                        <TableColumn fx:id="colNiveau" text="Niveau" prefWidth="150" minWidth="120"/>
                        <TableColumn fx:id="colActif" text="Actif" prefWidth="80" minWidth="60"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
            
            <!-- Panel droit: Formulaire d'édition -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20;">
                <Label text="✏️ Édition du Service" styleClass="section-title"/>
                
                <Separator/>
                
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <VBox spacing="15">
                        <padding>
                            <Insets right="10"/>
                        </padding>
                        
                        <!-- Code du service -->
                        <VBox spacing="5">
                            <Label text="Code du Service *" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="tfServiceCode" promptText="Ex: CEMAA, MAGE, SCRH..." 
                                     maxWidth="Infinity"/>
                            <Label text="Code unique en majuscules" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                        </VBox>
                        
                        <!-- Nom du service -->
                        <VBox spacing="5">
                            <Label text="Nom du Service *" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="tfServiceName" promptText="Ex: Chef d'État-Major de l'Armée de l'Air" 
                                     maxWidth="Infinity"/>
                            <Label text="Nom complet du service" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                        </VBox>
                        
                        <!-- Service parent -->
                        <VBox spacing="5">
                            <Label text="Service Parent" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="cbParentService" promptText="Sélectionner le service parent..." 
                                    maxWidth="Infinity"/>
                            <Label text="Laisser vide pour un service racine" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                        </VBox>
                        
                        <!-- Niveau hiérarchique -->
                        <VBox spacing="5">
                            <Label text="Niveau Hiérarchique *" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="cbNiveau" promptText="Sélectionner le niveau..." 
                                    maxWidth="Infinity"/>
                            <VBox spacing="3" style="-fx-background-color: #f0f8ff; -fx-padding: 10; -fx-background-radius: 5;">
                                <Label text="📥 Niveau -1: Service Courrier" style="-fx-font-size: 10px;"/>
                                <Label text="⭐ Niveau 0: CEMAA, CSP (Autorité suprême)" style="-fx-font-size: 10px;"/>
                                <Label text="🎖️ Niveau 1: MAGE, CSA (Major Général)" style="-fx-font-size: 10px;"/>
                                <Label text="🏢 Niveau 2: CSHAA, CACOM, SCRH, etc." style="-fx-font-size: 10px;"/>
                                <Label text="📁 Niveau 3: Sous-services (CB*)" style="-fx-font-size: 10px;"/>
                                <Label text="👤 Niveau 4: Chefs d'Équipe (CE)" style="-fx-font-size: 10px;"/>
                                <Label text="👥 Niveau 5: Chefs d'Équipe Adjoints (CEA)" style="-fx-font-size: 10px;"/>
                            </VBox>
                        </VBox>
                        
                        <!-- Ordre d'affichage -->
                        <VBox spacing="5">
                            <Label text="Ordre d'Affichage" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="tfOrdreAffichage" promptText="1" maxWidth="Infinity"/>
                            <Label text="Ordre d'affichage dans les listes (1, 2, 3...)" 
                                 style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                        </VBox>
                        
                        <!-- Service actif -->
                        <VBox spacing="5">
                            <CheckBox fx:id="chkActif" text="Service actif" selected="true"/>
                            <Label text="Décocher pour désactiver temporairement le service" 
                                 style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;"/>
                        </VBox>
                        
                        <Separator/>
                        
                        <!-- Boutons d'action -->
                        <VBox spacing="10">
                            <Button fx:id="btnSaveService" text="💾 Créer le Service" 
                                  onAction="#handleSaveService" 
                                  styleClass="button-success" 
                                  maxWidth="Infinity" 
                                  prefHeight="40"/>
                            
                            <Button fx:id="btnDeleteService" text="🗑️ Supprimer le Service" 
                                  onAction="#handleDeleteService" 
                                  styleClass="button-danger" 
                                  maxWidth="Infinity" 
                                  prefHeight="35"
                                  disable="true"/>
                            
                            <Button fx:id="btnNewService" text="🆕 Nouveau Service" 
                                  onAction="#handleNewService" 
                                  styleClass="button-info" 
                                  maxWidth="Infinity" 
                                  prefHeight="35"/>
                        </VBox>
                        
                        <Separator/>
                        
                        <!-- Informations supplémentaires -->
                        <VBox spacing="10" style="-fx-background-color: #fffacd; -fx-padding: 15; -fx-background-radius: 8;">
                            <Label text="ℹ️ Informations" style="-fx-font-weight: bold;"/>
                            <Label text="• Les codes doivent être uniques" wrapText="true" style="-fx-font-size: 11px;"/>
                            <Label text="• Un service parent doit être du niveau supérieur" wrapText="true" style="-fx-font-size: 11px;"/>
                            <Label text="• Niveau 0 = autorité maximale" wrapText="true" style="-fx-font-size: 11px;"/>
                            <Label text="• Les services désactivés restent visibles dans l'historique" wrapText="true" style="-fx-font-size: 11px;"/>
                        </VBox>
                        
                    </VBox>
                </ScrollPane>
            </VBox>
            
        </SplitPane>
    </center>
    
    <!-- Bas: Zone de visualisation -->
    <bottom>
        <VBox fx:id="hierarchyVisualization" spacing="10" style="-fx-background-color: white; -fx-padding: 15;">
            <!-- La visualisation sera générée dynamiquement -->
        </VBox>
    </bottom>
    
</BorderPane>
