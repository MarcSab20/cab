<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="application.controllers.AdministrationController">
   
   <top>
      <VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: white;">
         <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold;" text="⚙️ Administration">
            <font>
               <Font size="24.0" />
            </font>
         </Label>
         <Label style="-fx-text-fill: #7f8c8d;" text="Gérer la configuration système, les logs et les codes confidentiels" />
      </VBox>
   </top>
   
   <center>
      <TabPane fx:id="tabPaneAdmin" tabClosingPolicy="UNAVAILABLE">
         
         <!-- NOUVEL ONGLET : Codes Confidentiels -->
         <Tab text="🔐 Codes Confidentiels">
            <ScrollPane fitToWidth="true">
               <VBox spacing="20.0" style="-fx-padding: 30;">
                  
                  <!-- Avertissement de sécurité -->
                  <VBox spacing="10.0" style="-fx-background-color: #fff3cd; -fx-padding: 15; -fx-background-radius: 6; -fx-border-color: #ffc107; -fx-border-width: 2; -fx-border-radius: 6;">
                     <Label style="-fx-font-weight: bold; -fx-text-fill: #856404; -fx-font-size: 14px;" text="ZONE SÉCURISÉE - ADMINISTRATEURS UNIQUEMENT" />
                     <Label style="-fx-text-fill: #856404; -fx-font-size: 12px;" 
                           text="Cette section permet de gérer les codes confidentiels du système. Tous les changements sont enregistrés et tracés." 
                           wrapText="true" />
                  </VBox>
                  
                  <!-- Code confidentiel actuel -->
                  <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2); -fx-background-radius: 8;">
                     <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Code confidentiel actuel" />
                     
                     <GridPane hgap="15.0" vgap="12.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="NEVER" minWidth="200.0" />
                           <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        
                        <Label text="Statut du code:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="lblStatutCodeActuel" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" 
                              text="✅ Actif" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label fx:id="lblDescriptionCodeActuel" text="Code confidentiel du système" 
                              GridPane.columnIndex="1" GridPane.rowIndex="1" wrapText="true" />
                        
                        <Label text="Créé par:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label fx:id="lblCreateurCodeActuel" text="Système" 
                              GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        
                        <Label text="Date de création:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <Label fx:id="lblDateCreationCodeActuel" text="--/--/---- --:--" 
                              GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        
                        <Label text="Jours depuis création:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <Label fx:id="lblJoursDepuisCreation" text="0 jours" 
                              GridPane.columnIndex="1" GridPane.rowIndex="4" />
                     </GridPane>
                     
                     <Separator />
                     
                     <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="btnChangerCode" styleClass="button-primary" 
                               text="🔑 Changer le code confidentiel" 
                               onAction="#handleChangerCodeConfidentiel" />
                        <Button fx:id="btnActualiserCodeInfo" styleClass="button-secondary" 
                               text="🔄 Actualiser" 
                               onAction="#handleActualiserCodeInfo" />
                     </HBox>
                  </VBox>
                  
                  <!-- Statistiques d'accès -->
                  <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2); -fx-background-radius: 8;">
                     <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Statistiques d'accès aux ressources confidentielles" />
                     
                     <GridPane hgap="30.0" vgap="12.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="ALWAYS" />
                           <ColumnConstraints hgrow="ALWAYS" />
                           <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        
                        <!-- Colonne 1 -->
                        <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                           <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Total tentatives" />
                           <Label fx:id="lblStatTotalTentatives" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0" />
                        </VBox>
                        
                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                           <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Accès réussis" />
                           <Label fx:id="lblStatAccesReussis" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="0" />
                        </VBox>
                        
                        <VBox spacing="5.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                           <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Accès refusés" />
                           <Label fx:id="lblStatAccesRefuses" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" text="0" />
                        </VBox>
                        
                        <!-- Colonne 2 -->
                        <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                           <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Utilisateurs ayant accès" />
                           <Label fx:id="lblStatUtilisateursAcces" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;" text="0" />
                        </VBox>
                        
                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                           <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Total codes créés" />
                           <Label fx:id="lblStatTotalCodes" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #34495e;" text="0" />
                        </VBox>
                        
                        <VBox spacing="5.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
                           <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="Codes actifs" />
                           <Label fx:id="lblStatCodesActifs" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #16a085;" text="0" />
                        </VBox>
                     </GridPane>
                  </VBox>
                  
                  <!-- Historique des codes -->
                  <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2); -fx-background-radius: 8;">
                     <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Historique des codes confidentiels" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnActualiserHistorique" text="🔄 Actualiser" 
                               onAction="#handleActualiserHistorique" />
                     </HBox>
                     
                     <TableView fx:id="tableHistoriqueCode" prefHeight="300.0">
                        <columns>
                           <TableColumn fx:id="colHistoriqueDescription" prefWidth="300.0" text="Description" />
                           <TableColumn fx:id="colHistoriqueStatut" prefWidth="100.0" text="Statut" />
                           <TableColumn fx:id="colHistoriqueCreateur" prefWidth="150.0" text="Créé par" />
                           <TableColumn fx:id="colHistoriqueDateCreation" prefWidth="150.0" text="Date création" />
                           <TableColumn fx:id="colHistoriqueAge" prefWidth="100.0" text="Âge (jours)" />
                        </columns>
                        
                        <placeholder>
                           <VBox alignment="CENTER" spacing="10.0">
                              <Label style="-fx-font-size: 48px; -fx-text-fill: #bdc3c7;" text="🔐" />
                              <Label style="-fx-text-fill: #7f8c8d;" text="Aucun historique disponible" />
                           </VBox>
                        </placeholder>
                     </TableView>
                  </VBox>
                  
                  <!-- Responsable courriers confidentiels -->
                  <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2); -fx-background-radius: 8;">
                     <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Responsable des courriers confidentiels" />
                     
                     <VBox spacing="10.0">
                        <Label text="Le responsable recevra automatiquement tous les nouveaux courriers confidentiels créés." 
                              style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;" wrapText="true" />
                     </VBox>
                     
                     <GridPane hgap="15.0" vgap="12.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="NEVER" minWidth="200.0" />
                           <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        
                        <Label text="Responsable actuel:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="lblResponsableCourrierConfidentiel" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" 
                              text="Aucun responsable configuré" 
                              GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Sélectionner un responsable:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <ComboBox fx:id="cmbResponsableCourrierConfidentiel" promptText="Choisir un utilisateur..." 
                                 prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                     </GridPane>
                     
                     <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="btnDefinirResponsableConfidentiel" styleClass="button-primary" 
                               text="✅ Définir comme responsable" 
                               onAction="#handleDefinirResponsableConfidentiel" />
                        <Button fx:id="btnSupprimerResponsableConfidentiel" styleClass="button-danger" 
                               text="❌ Supprimer le responsable" 
                               onAction="#handleSupprimerResponsableConfidentiel" />
                        <Button fx:id="btnActualiserResponsableConfidentiel" styleClass="button-secondary" 
                               text="🔄 Actualiser" 
                               onAction="#handleActualiserResponsableConfidentiel" />
                     </HBox>
                  </VBox>
                  
               </VBox>
            </ScrollPane>
         </Tab>
         
         <!-- Onglet Configuration Serveur (EXISTANT) -->
         <Tab text="🖥️ Configuration Serveur">
            <ScrollPane fitToWidth="true">
               <VBox spacing="20.0" style="-fx-padding: 30;">
                  
                  <!-- Configuration du serveur de stockage -->
                  <VBox spacing="15.0" styleClass="card" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2); -fx-background-radius: 8;">
                     <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Configuration du serveur de stockage" />
                     
                     <GridPane hgap="15.0" vgap="12.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="NEVER" minWidth="150.0" />
                           <ColumnConstraints hgrow="ALWAYS" />
                           <ColumnConstraints hgrow="NEVER" />
                        </columnConstraints>
                        
                        <Label text="Chemin du serveur:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtCheminServeur" promptText="C:\DocumentManagement\serveur" 
                                 GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Button fx:id="btnParcourirServeur" text="📁 Parcourir" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        
                        <Label text="Serveur actif:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <CheckBox fx:id="chkServeurActif" text="Activer le stockage sur serveur" 
                                GridPane.columnIndex="1" GridPane.rowIndex="1" />
                     </GridPane>
                     
                     <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="btnSauvegarderConfig" styleClass="button-primary" text="💾 Sauvegarder" />
                        <Button fx:id="btnTesterConnexion" styleClass="button-secondary" text="🔌 Tester la connexion" />
                     </HBox>
                  </VBox>
                  
                  <!-- Statistiques du serveur -->
                  <VBox spacing="15.0" styleClass="card" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2); -fx-background-radius: 8;">
                     <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Statistiques du serveur" />
                     
                     <GridPane hgap="15.0" vgap="12.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="NEVER" minWidth="180.0" />
                           <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        
                        <Label text="Statut du serveur:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="lblStatutServeur" style="-fx-font-weight: bold;" text="🟢 Actif" 
                              GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Nombre de fichiers:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label fx:id="lblNombreFichiers" text="0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label text="Taille totale:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label fx:id="lblTailleTotale" text="0 B" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        
                        <Label text="Espace disponible:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <Label fx:id="lblEspaceDisponible" text="0 B" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                     </GridPane>
                  </VBox>
                  
               </VBox>
            </ScrollPane>
         </Tab>
         
         <!-- Onglet Configuration Responsable Courrier Standards (EXISTANT) -->
		<Tab text="📧 Responsable Courriers Standards">
		   <ScrollPane fitToWidth="true">
		      <VBox spacing="20.0" style="-fx-padding: 30;">
		         
		         <!-- Configuration du responsable -->
		         <VBox spacing="15.0" styleClass="card" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2); -fx-background-radius: 8;">
		            <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Configuration du responsable des courriers standards" />
		            
		            <VBox spacing="10.0">
		               <Label text="Le responsable recevra automatiquement tous les nouveaux courriers standards créés dans le système." 
		                     style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;" wrapText="true" />
		            </VBox>
		            
		            <GridPane hgap="15.0" vgap="12.0">
		               <columnConstraints>
		                  <ColumnConstraints hgrow="NEVER" minWidth="150.0" />
		                  <ColumnConstraints hgrow="ALWAYS" />
		               </columnConstraints>
		               
		               <Label text="Responsable actuel:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
		               <Label fx:id="lblResponsableActuel" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" 
		                     text="Aucun responsable configuré" 
		                     GridPane.columnIndex="1" GridPane.rowIndex="0" />
		               
		               <Label text="Sélectionner un nouveau responsable:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
		               <ComboBox fx:id="cmbResponsableCourrier" promptText="Choisir un utilisateur..." 
		                        prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
		            </GridPane>
		            
		            <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
		               <Button fx:id="btnDefinirResponsable" styleClass="button-primary" text="✅ Définir comme responsable" />
		               <Button fx:id="btnSupprimerResponsable" styleClass="button-danger" text="❌ Supprimer le responsable" />
		               <Button fx:id="btnActualiserResponsable" styleClass="button-secondary" text="🔄 Actualiser" />
		            </HBox>
		         </VBox>
		         
		         <!-- Statistiques des notifications -->
		         <VBox spacing="15.0" styleClass="card" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2); -fx-background-radius: 8;">
		            <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Statistiques des notifications" />
		            
		            <GridPane hgap="15.0" vgap="12.0">
		               <columnConstraints>
		                  <ColumnConstraints hgrow="NEVER" minWidth="200.0" />
		                  <ColumnConstraints hgrow="ALWAYS" />
		               </columnConstraints>
		               
		               <Label text="Courriers notifiés (total):" GridPane.columnIndex="0" GridPane.rowIndex="0" />
		               <Label fx:id="lblTotalNotifications" style="-fx-font-weight: bold;" text="0" 
		                     GridPane.columnIndex="1" GridPane.rowIndex="0" />
		               
		               <Label text="Courriers non lus:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
		               <Label fx:id="lblNotificationsNonLues" style="-fx-font-weight: bold; -fx-text-fill: #e74c3c;" text="0" 
		                     GridPane.columnIndex="1" GridPane.rowIndex="1" />
		            </GridPane>
		         </VBox>
		         
		      </VBox>
		   </ScrollPane>
		</Tab>
         
         <!-- Onglet Logs d'activité (EXISTANT - inchangé) -->
         <Tab text="📋 Logs d'activité">
            <VBox spacing="20.0" style="-fx-padding: 20;">
               
               <!-- Filtres -->
               <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-background-radius: 6;">
                  <Label text="Période:" />
                  <DatePicker fx:id="dateDebutLogs" promptText="Du" prefWidth="140.0" />
                  <Label text="au" />
                  <DatePicker fx:id="dateFinLogs" promptText="Au" prefWidth="140.0" />
                  
                  <Separator orientation="VERTICAL" />
                  
                  <Label text="Type:" />
                  <ComboBox fx:id="cmbTypeAction" prefWidth="150.0" />
                  
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <TextField fx:id="txtRechercheLog" promptText="🔍 Rechercher..." prefWidth="200.0" />
                  <Button fx:id="btnRechercherLogs" styleClass="button-primary" text="Rechercher" />
               </HBox>
               
               <!-- Tableau des logs -->
               <TableView fx:id="tableLogs" VBox.vgrow="ALWAYS">
                  <columns>
                     <TableColumn fx:id="colLogDate" prefWidth="150.0" text="Date/Heure" />
                     <TableColumn fx:id="colLogUtilisateur" prefWidth="150.0" text="Utilisateur" />
                     <TableColumn fx:id="colLogAction" prefWidth="120.0" text="Action" />
                     <TableColumn fx:id="colLogDetails" prefWidth="300.0" text="Détails" />
                     <TableColumn fx:id="colLogIP" prefWidth="120.0" text="Adresse IP" />
                     <TableColumn fx:id="colLogStatut" prefWidth="120.0" text="Statut" />
                  </columns>
                  
                  <placeholder>
                     <VBox alignment="CENTER" spacing="10.0">
                        <Label style="-fx-font-size: 48px; -fx-text-fill: #bdc3c7;" text="📋" />
                        <Label style="-fx-text-fill: #7f8c8d;" text="Aucun log disponible" />
                     </VBox>
                  </placeholder>
               </TableView>
               
               <!-- Actions -->
               <HBox spacing="10.0" alignment="CENTER_LEFT">
                  <Button fx:id="btnExporterLogs" styleClass="button-secondary" text="📥 Exporter les logs" />
                  <Button fx:id="btnViderLogs" styleClass="button-danger" text="🗑️ Vider les anciens logs (> 3 mois)" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" 
                        text="Affichage des 1000 derniers logs" />
               </HBox>
               
            </VBox>
         </Tab>
         
         <!-- Onglet Connexions (EXISTANT - inchangé) -->
         <Tab text="🔐 Connexions">
            <VBox spacing="20.0" style="-fx-padding: 20;">
               
               <!-- Filtres -->
               <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-background-radius: 6;">
                  <Label text="Période:" />
                  <DatePicker fx:id="dateDebutConnexions" promptText="Du" prefWidth="140.0" />
                  <Label text="au" />
                  <DatePicker fx:id="dateFinConnexions" promptText="Au" prefWidth="140.0" />
                  
                  <Separator orientation="VERTICAL" />
                  
                  <Label text="Type:" />
                  <ComboBox fx:id="cmbTypeConnexion" prefWidth="150.0" />
                  
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <Button fx:id="btnRechercherConnexions" styleClass="button-primary" text="Rechercher" />
               </HBox>
               
               <!-- Tableau des connexions -->
               <TableView fx:id="tableConnexions" VBox.vgrow="ALWAYS">
                  <columns>
                     <TableColumn fx:id="colConnexionDate" prefWidth="150.0" text="Date/Heure" />
                     <TableColumn fx:id="colConnexionUtilisateur" prefWidth="180.0" text="Utilisateur" />
                     <TableColumn fx:id="colConnexionRole" prefWidth="120.0" text="Role" />
					 <TableColumn fx:id="colConnexionDuree" prefWidth="120.0" text="Duree" />
                     <TableColumn fx:id="colConnexionType" prefWidth="150.0" text="Type" />
                     <TableColumn fx:id="colConnexionIP" prefWidth="150.0" text="Adresse IP" />
                     <TableColumn fx:id="colConnexionStatut" prefWidth="150.0" text="Statut" />
                  </columns>
                  
                  <placeholder>
                     <VBox alignment="CENTER" spacing="10.0">
                        <Label style="-fx-font-size: 48px; -fx-text-fill: #bdc3c7;" text="🔐" />
                        <Label style="-fx-text-fill: #7f8c8d;" text="Aucune connexion enregistrée" />
                     </VBox>
                  </placeholder>
               </TableView>
               
               <!-- Actions -->
               <HBox spacing="10.0" alignment="CENTER_LEFT">
                  <Button fx:id="btnExporterConnexions" styleClass="button-secondary" text="📥 Exporter" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" 
                        text="Affichage des 500 dernières connexions" />
               </HBox>
               
            </VBox>
         </Tab>
         
      </TabPane>
   </center>
   
</BorderPane>
