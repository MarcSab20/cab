<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="application.controllers.WorkflowGraphController"
            style="-fx-background-color: #f5f6fa;"
            minWidth="1000" minHeight="700" prefWidth="1200" prefHeight="800">
   
   <!-- Barre supérieure -->
   <top>
      <VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
         
         <!-- En-tête -->
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Label style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 24px;" 
                   text="📊 Analyse Workflow - Visualisation par Graphes" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="↻ Actualiser" onAction="#handleActualiser"
                   style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5; -fx-padding: 10 20;" />
            <Button text="💾 Exporter" onAction="#handleExportGraph"
                   style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5; -fx-padding: 10 20;" />
         </HBox>
         
         <!-- Filtres et options -->
         <GridPane hgap="15.0" vgap="10.0">
            <columnConstraints>
               <ColumnConstraints percentWidth="25.0" />
               <ColumnConstraints percentWidth="35.0" />
               <ColumnConstraints percentWidth="20.0" />
               <ColumnConstraints percentWidth="20.0" />
            </columnConstraints>
            
            <!-- Mode de vue -->
            <VBox spacing="5.0" GridPane.columnIndex="0">
               <Label text="Mode de visualisation:" style="-fx-font-weight: 600; -fx-text-fill: #7f8c8d;" />
               <ComboBox fx:id="cbModVue" prefWidth="240.0" 
                        style="-fx-background-radius: 5;" />
            </VBox>
            
            <!-- Sélection courrier individuel -->
            <VBox spacing="5.0" GridPane.columnIndex="1">
               <Label text="Courrier (vue individuelle):" style="-fx-font-weight: 600; -fx-text-fill: #7f8c8d;" />
               <ComboBox fx:id="cbCourrierIndividuel" maxWidth="1.7976931348623157E308" disable="true"
                        promptText="Sélectionner un courrier..."
                        style="-fx-background-radius: 5;" />
            </VBox>
            
            <!-- Date début -->
            <VBox spacing="5.0" GridPane.columnIndex="2">
               <Label text="Période (du):" style="-fx-font-weight: 600; -fx-text-fill: #7f8c8d;" />
               <DatePicker fx:id="dpDebut" maxWidth="1.7976931348623157E308"
                          style="-fx-background-radius: 5;" />
            </VBox>
            
            <!-- Date fin -->
            <VBox spacing="5.0" GridPane.columnIndex="3">
               <Label text="Au:" style="-fx-font-weight: 600; -fx-text-fill: #7f8c8d;" />
               <DatePicker fx:id="dpFin" maxWidth="1.7976931348623157E308"
                          style="-fx-background-radius: 5;" />
            </VBox>
         </GridPane>
         
         <!-- Bouton de génération -->
         <HBox alignment="CENTER" spacing="15.0">
            <Button text="🎯 Générer le Graphe" onAction="#handleGenerateGraph"
                   style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5; -fx-padding: 12 30;" />
            <CheckBox fx:id="chkAfficherStatistiques" text="Afficher statistiques détaillées" 
                     selected="true"
                     style="-fx-font-weight: 600;" />
         </HBox>
         
      </VBox>
   </top>
   
   <!-- Zone principale -->
   <center>
      <SplitPane dividerPositions="0.45" orientation="HORIZONTAL">
         
         <!-- Visualisation du graphe -->
         <VBox spacing="10.0" style="-fx-padding: 20;">
            
            <HBox alignment="CENTER_LEFT" spacing="15.0" 
                  style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-background-radius: 5;">
               <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" 
                      text="📈 Visualisation des Flux" />
               <Region HBox.hgrow="ALWAYS" />
               
               <!-- Légende -->
               <VBox spacing="5.0">
                  <Label text="Légende:" style="-fx-font-weight: 600; -fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                  <HBox spacing="15.0">
                     <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label style="-fx-background-color: #27ae60; -fx-min-width: 15; -fx-min-height: 15; -fx-background-radius: 50%;" />
                        <Label text="Bon (≥80%)" style="-fx-font-size: 10px;" />
                     </HBox>
                     <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label style="-fx-background-color: #f39c12; -fx-min-width: 15; -fx-min-height: 15; -fx-background-radius: 50%;" />
                        <Label text="Moyen (60-79%)" style="-fx-font-size: 10px;" />
                     </HBox>
                     <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label style="-fx-background-color: #e74c3c; -fx-min-width: 15; -fx-min-height: 15; -fx-background-radius: 50%;" />
                        <Label text="Faible (inf 60%)" style="-fx-font-size: 10px;" />
                     </HBox>
                     <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label text="⚠️" style="-fx-font-size: 14px;" />
                        <Label text="Goulot" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #c0392b;" />
                     </HBox>
                  </HBox>
               </VBox>
            </HBox>
            
            <!-- Zone de dessin du graphe -->
            <ScrollPane fx:id="graphScrollPane" fitToWidth="true" fitToHeight="true"
                       VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;">
               <Pane fx:id="graphPane" style="-fx-background-color: #f8f9fa;">
                  <!-- Le graphe sera dessiné ici dynamiquement -->
               </Pane>
            </ScrollPane>
            
            <!-- Informations sur le graphe -->
            <HBox alignment="CENTER" spacing="20.0" 
                  style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-background-radius: 5;">
               <Label text="💡 Conseil:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
               <Label text="Survolez les nœuds pour voir les détails. Les nœuds rouges indiquent des goulots d'étranglement."
                      style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" 
                      wrapText="true" />
            </HBox>
            
         </VBox>
         
         <!-- Panneau des statistiques -->
         <VBox spacing="15.0" style="-fx-padding: 20;">
            
            <!-- Titre -->
            <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;" 
                   text="📊 Statistiques Globales" />
            
            <!-- Statistiques résumées -->
            <GridPane hgap="15.0" vgap="15.0">
               <columnConstraints>
                  <ColumnConstraints percentWidth="50.0" />
                  <ColumnConstraints percentWidth="50.0" />
               </columnConstraints>
               
               <!-- Total courriers -->
               <VBox alignment="CENTER" spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0"
                     style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #3498db; -fx-border-width: 2; -fx-border-radius: 10;">
                  <Label text="📧" style="-fx-font-size: 28px;" />
                  <Label fx:id="statTotalCourriers" text="0" 
                         style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                  <Label text="Total traités" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
               </VBox>
               
               <!-- Durée moyenne -->
               <VBox alignment="CENTER" spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0"
                     style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #f39c12; -fx-border-width: 2; -fx-border-radius: 10;">
                  <Label text="⏱️" style="-fx-font-size: 28px;" />
                  <Label fx:id="statDureeMoyenne" text="0h" 
                         style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" />
                  <Label text="Durée moyenne" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
               </VBox>
               
               <!-- Taux de réussite -->
               <VBox alignment="CENTER" spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1"
                     style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #27ae60; -fx-border-width: 2; -fx-border-radius: 10;">
                  <Label text="✅" style="-fx-font-size: 28px;" />
                  <Label fx:id="statTauxReussite" text="0%" 
                         style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                  <Label text="Taux de réussite" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
               </VBox>
               
               <!-- Goulots d'étranglement -->
               <VBox alignment="CENTER" spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1"
                     style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e74c3c; -fx-border-width: 2; -fx-border-radius: 10;">
                  <Label text="⚠️" style="-fx-font-size: 28px;" />
                  <Label fx:id="statGoulots" text="0" 
                         style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
                  <Label text="Goulots détectés" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
               </VBox>
            </GridPane>
            
            <Separator />
            
            <!-- Tableau détaillé -->
            <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" 
                   text="📋 Détails par Service" />
            
            <TableView fx:id="tableStats" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 10;">
               <columns>
                  <TableColumn fx:id="colService" text="Service" prefWidth="120.0" />
                  <TableColumn fx:id="colTotal" text="Total" prefWidth="60.0" 
                              style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colEnCours" text="En cours" prefWidth="70.0" 
                              style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colDuree" text="Durée" prefWidth="80.0" 
                              style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colScore" text="Score" prefWidth="70.0" 
                              style="-fx-alignment: CENTER;" />
               </columns>
               
               <placeholder>
                  <VBox alignment="CENTER" spacing="10.0" style="-fx-padding: 30;">
                     <Label text="📊" style="-fx-font-size: 48px; -fx-text-fill: #bdc3c7;" />
                     <Label text="Aucune statistique disponible" 
                            style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" />
                  </VBox>
               </placeholder>
            </TableView>
            
            <!-- Notes explicatives -->
            <VBox spacing="8.0" 
                  style="-fx-background-color: #e8f4f8; -fx-padding: 15; -fx-background-radius: 8;">
               <Label text="ℹ️ Interprétation du Score de Performance:" 
                      style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #2c3e50;" />
               <Label text="• ≥ 80% : Performance excellente" 
                      style="-fx-text-fill: #27ae60; -fx-font-size: 11px;" />
               <Label text="• 60-79% : Performance satisfaisante" 
                      style="-fx-text-fill: #f39c12; -fx-font-size: 11px;" />
               <Label text="• inf 60% : Nécessite amélioration" 
                      style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" />
               
               <Separator />
               
               <Label text="⚠️ Goulot d'étranglement détecté si:" 
                      style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #2c3e50;" />
               <Label text="• Délai d'attente > 24h avant traitement" 
                      style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
               <Label text="• Plus de 30% des courriers en retard" 
                      style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
            </VBox>
            
         </VBox>
         
      </SplitPane>
   </center>
   
</BorderPane>
