<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controllers.LoginController">
   
   <!-- Arrière-plan -->
   <center>
      <HBox alignment="CENTER" style="-fx-background-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
         
         <!-- Conteneur principal de login -->
         <VBox alignment="CENTER" maxHeight="500.0" maxWidth="400.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 5);">
            <padding>
               <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            
            <!-- En-tête avec logo -->
            <VBox alignment="CENTER" spacing="10.0">
               <ImageView fitHeight="60.0" fitWidth="60.0" preserveRatio="true">
                  <image>
                     <Image url="@../images/logo.png" />
                  </image>
               </ImageView>
               <Label style="-fx-text-fill: #333333; -fx-font-weight: bold;" text="Gestion Documentaire">
                  <font>
                     <Font size="24.0" />
                  </font>
               </Label>
               <Label style="-fx-text-fill: #666666;" text="Connectez-vous à votre compte">
                  <font>
                     <Font size="14.0" />
                  </font>
               </Label>
            </VBox>
            
            <!-- Formulaire de connexion -->
            <VBox spacing="15.0">
               
               <!-- Champ Code utilisateur -->
               <VBox spacing="5.0">
                  <Label style="-fx-text-fill: #333333; -fx-font-weight: bold;" text="Code utilisateur:" />
                  <TextField fx:id="codeField" promptText="Saisissez votre code" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-padding: 12;">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </TextField>
               </VBox>
               
               <!-- Champ Mot de passe -->
               <VBox spacing="5.0">
                  <Label style="-fx-text-fill: #333333; -fx-font-weight: bold;" text="Mot de passe:" />
                  <PasswordField fx:id="passwordField" promptText="Saisissez votre mot de passe" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-padding: 12;">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </PasswordField>
               </VBox>
               
               <!-- Sélection du rôle -->
               <VBox spacing="5.0">
                  <Label style="-fx-text-fill: #333333; -fx-font-weight: bold;" text="Rôle:" />
                  <ComboBox fx:id="roleComboBox" maxWidth="1.7976931348623157E308" promptText="Sélectionnez votre rôle" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e0e0e0; -fx-border-width: 1;">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </ComboBox>
               </VBox>
               
               <!-- Messages de statut -->
               <Label fx:id="statusLabel" style="-fx-text-fill: #d32f2f;" textAlignment="CENTER" wrapText="true">
                  <font>
                     <Font size="12.0" />
                  </font>
               </Label>
               
               <!-- Indicateur de chargement -->
               <HBox alignment="CENTER">
                  <ProgressIndicator fx:id="loadingIndicator" maxHeight="30.0" maxWidth="30.0" />
               </HBox>
               
               <!-- Bouton de connexion -->
               <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" onAction="#handleLogin" style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-padding: 12;" text="Se connecter">
                  <font>
                     <Font size="16.0" />
                  </font>
               </Button>
               
               <!-- Lien mot de passe oublié -->
               <HBox alignment="CENTER">
                  <Hyperlink onAction="#handleForgotPassword" style="-fx-text-fill: #667eea;" text="Mot de passe oublié ?" />
               </HBox>
               
            </VBox>
            
         </VBox>
         
      </HBox>
   </center>
   
   <!-- Pied de page avec informations -->
   <bottom>
      <VBox alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 15;">
         <Label style="-fx-text-fill: white; -fx-font-size: 12px;" text="Système de Gestion Documentaire v1.0" />
         <Label style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 10px;" text="© 2025 - Tous droits réservés" />
      </VBox>
   </bottom>
   
</BorderPane>